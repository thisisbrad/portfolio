---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import TagFilter from '../../../components/TagFilter.astro';

const posts = (await getCollection('posts'))
  .filter(p => p.data.type === 'the-search')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postCount = posts.length;
---

<BaseLayout
  title="The Search — BRAD.DEV"
  description="A raw account of the job search. Two rejections, one callback, and everything in between."
  type="the-search"
  activeLink="writing"
>
  <div class="site-wrapper">

    <section class="ts-hero scroll-reveal">
      <div class="ts-hero-text">
        <span class="ts-count-pill">
          {postCount} {postCount === 1 ? 'entry' : 'entries'}
        </span>
        <h1 class="ts-title">The<br />Search</h1>
        <p class="ts-tagline">Job hunting, raw and real.</p>
      </div>

      <div class="ts-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="160" height="160">
          <defs>
            <style>
              .ts-bg{transform-origin:50px 50px;animation:tsSqIn 0.45s cubic-bezier(0.34,1.4,0.64,1) both}
              @keyframes tsSqIn{from{transform:scale(0.5);opacity:0}to{transform:scale(1);opacity:1}}
              .ts-r1{transform-origin:50px 50px;animation:tsRing 0.5s 0.15s cubic-bezier(0.34,1.4,0.64,1) both}
              .ts-r2{transform-origin:50px 50px;animation:tsRing 0.5s 0.28s cubic-bezier(0.34,1.4,0.64,1) both}
              .ts-r3{transform-origin:50px 50px;animation:tsRing 0.5s 0.4s cubic-bezier(0.34,1.4,0.64,1) both}
              .ts-cd{transform-origin:50px 50px;animation:tsRing 0.4s 0.52s cubic-bezier(0.34,1.8,0.64,1) both}
              @keyframes tsRing{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
              .ts-orbit{transform-origin:50px 50px;stroke-dasharray:6 10;opacity:0;animation:tsOrbitIn 0.4s 0.8s ease forwards,tsSpin 5s 1.2s linear infinite}
              @keyframes tsOrbitIn{to{opacity:0.4}}
              @keyframes tsSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
              .ts-ch{stroke-dasharray:12;stroke-dashoffset:12;animation:tsDrawCH 0.3s ease forwards}
              .ts-ch1{animation-delay:.58s}.ts-ch2{animation-delay:.64s}.ts-ch3{animation-delay:.70s}.ts-ch4{animation-delay:.76s}
              @keyframes tsDrawCH{to{stroke-dashoffset:0}}
              .ts-icon-group{cursor:pointer}
              .ts-icon-group:hover .ts-orbit{animation:tsSpin 1.5s linear infinite;opacity:0.65}
            </style>
          </defs>
          <g class="ts-icon-group">
            <rect x="6" y="6" width="88" height="88" fill="#FF4D6A" opacity="0.22"/>
            <rect class="ts-bg" x="0" y="0" width="100" height="100" fill="#0d0d0d" stroke="#FF4D6A" stroke-width="3"/>
            <circle class="ts-r1" cx="50" cy="50" r="34" fill="#FF4D6A"/>
            <circle class="ts-r2" cx="50" cy="50" r="22" fill="none" stroke="#0d0d0d" stroke-width="5"/>
            <circle class="ts-r3" cx="50" cy="50" r="11" fill="#0d0d0d"/>
            <circle class="ts-cd" cx="50" cy="50" r="5" fill="#FF4D6A"/>
            <circle class="ts-orbit" cx="50" cy="50" r="42" fill="none" stroke="#FF4D6A" stroke-width="1.5"/>
            <line class="ts-ch ts-ch1" x1="50" y1="4"  x2="50" y2="14" stroke="#f5f0e8" stroke-width="3" stroke-linecap="round"/>
            <line class="ts-ch ts-ch2" x1="50" y1="86" x2="50" y2="96" stroke="#f5f0e8" stroke-width="3" stroke-linecap="round"/>
            <line class="ts-ch ts-ch3" x1="4"  y1="50" x2="14" y2="50" stroke="#f5f0e8" stroke-width="3" stroke-linecap="round"/>
            <line class="ts-ch ts-ch4" x1="86" y1="50" x2="96" y2="50" stroke="#f5f0e8" stroke-width="3" stroke-linecap="round"/>
          </g>
        </svg>
      </div>

      <!-- Decorative hollow circle bleeding off right edge -->
      <div class="ts-deco-circle" aria-hidden="true"></div>
    </section>

    <section class="posts-section scroll-reveal">
      <span class="section-label ts-section-label">// The Search</span>
      {posts.length > 0 ? (
        <>
          <TagFilter posts={posts} accent="coral" />
          <div class="posts-grid" data-posts-grid>
            {posts.map(post => (
              <div
                data-post-item
                data-tags={post.data.tags.join(',')}
                data-date={post.data.date.valueOf()}
              >
                <PostCard post={post} />
              </div>
            ))}
          </div>
          <button class="load-more-btn" data-load-more hidden>Show more →</button>
        </>
      ) : (
        <p class="empty-state">No entries yet. Stay tuned.</p>
      )}
    </section>

  </div>
</BaseLayout>

<style>
.ts-hero {
  position: relative;
  background: var(--black);
  border: 4px solid var(--coral);
  box-shadow: 10px 10px 0 var(--coral);
  padding: 52px 44px;
  margin: 40px 0 52px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: center;
  overflow: hidden;
  color: var(--white);
}

.ts-count-pill {
  display: inline-block;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--coral);
  color: var(--black);
  border: 2px solid var(--coral);
  padding: 4px 14px;
  margin-bottom: 16px;
}

.ts-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(3rem, 9vw, 5.5rem);
  letter-spacing: -0.04em;
  line-height: 0.88;
  color: var(--white);
  margin-bottom: 16px;
}

.ts-tagline {
  font-family: 'Lora', serif;
  font-style: italic;
  font-size: 1.05rem;
  color: rgba(245,240,232,0.65);
  margin: 0;
}

.ts-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--coral);
  box-shadow: 8px 8px 0 var(--coral);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  flex-shrink: 0;
}
.ts-icon-wrap:hover {
  transform: translate(-2px, -2px);
  box-shadow: 10px 10px 0 var(--coral);
}

/* Large hollow circle — bleeds off the right edge */
.ts-deco-circle {
  position: absolute;
  top: -50px;
  right: -60px;
  width: 240px;
  height: 240px;
  border: 36px solid var(--coral);
  border-radius: 50%;
  opacity: 0.1;
  pointer-events: none;
  z-index: 0;
}

.ts-hero-text {
  position: relative;
  z-index: 1;
}

/* Override section-label for dark/coral theme */
.ts-section-label {
  background: var(--coral) !important;
  color: var(--black) !important;
}

.posts-section {
  margin-bottom: 80px;
}
.posts-section .section-label {
  margin-bottom: 28px;
  display: inline-block;
}
.posts-grid {
  margin-top: 20px;
}

.load-more-btn {
  display: block;
  margin: 28px auto 0;
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  padding: 10px 24px;
  border: 2px solid var(--coral);
  background: var(--black);
  color: var(--coral);
  cursor: pointer;
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}
.load-more-btn:hover {
  transform: translate(-2px, -2px);
  box-shadow: 4px 4px 0 var(--coral);
}
.load-more-btn[hidden] { display: none; }

.empty-state {
  font-family: 'Space Mono', monospace;
  font-size: 0.85rem;
  color: rgba(13,13,13,0.5);
  margin-top: 24px;
  padding: 32px;
  border: 2px dashed rgba(13,13,13,0.2);
  text-align: center;
}

.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.posts-section.scroll-reveal {
  transition-delay: 0.1s;
}

@media (max-width: 640px) {
  .ts-hero {
    grid-template-columns: 1fr;
    padding: 36px 24px;
    margin: 24px 0 40px;
  }
  .ts-icon-wrap { display: none; }
  .ts-deco-circle { width: 160px; height: 160px; right: -40px; top: -30px; }
  .ts-title { font-size: clamp(2.8rem, 14vw, 4rem); }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
