---
interface Props {
  title: string;
  date: Date;
  readTime: string;
  tags: string[];
  lessonNumber?: number;
  subtitle?: string;
}
const { title, date, readTime, tags, lessonNumber, subtitle } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const lessonLabel = lessonNumber ? `Lesson ${String(lessonNumber).padStart(2, '0')}` : 'Hard Won';
---
<div class="post-header hardwon-header">
  <!-- Decorative slab stack top-right -->
  <div class="header-slabs">
    <div class="header-slab" style="width: 52px"></div>
    <div class="header-slab" style="width: 52px"></div>
    <div class="header-slab" style="width: 52px"></div>
    <div class="header-slab" style="width: 52px"></div>
    <div class="header-slab" style="width: 52px"></div>
  </div>

  <div class="section-badge hardwon-badge">
    <span class="badge-icon-burst" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="240" height="240" overflow="hidden">
  <defs>
    <style>
      .sq-rebel {
        animation: dropIn 0.45s 0.75s cubic-bezier(0.34,1.5,0.64,1) both;
      }
      @keyframes dropIn {
        from { transform: translate(-10px,-10px) rotate(-12deg); opacity: 0; }
        to   { transform: translate(0,0) rotate(-8deg); opacity: 1; }
      }
      .crown {
        transform-origin: 42px 18px;
        animation: crownPop 0.5s 0.9s cubic-bezier(0.34,1.8,0.64,1) both;
      }
      @keyframes crownPop {
        from { transform: scale(0); opacity: 0; }
        to   { transform: scale(1); opacity: 1; }
      }
      .slash {
        stroke-dasharray: 90;
        stroke-dashoffset: 90;
        animation: drawSlash 0.4s 1.05s cubic-bezier(0.4,0,0.2,1) forwards;
      }
      @keyframes drawSlash { to { stroke-dashoffset: 0; } }
      .accent-dot {
        transform-origin: 72px 52px;
        animation: dotBounce 0.45s 1.15s cubic-bezier(0.34,2,0.64,1) both;
      }
      @keyframes dotBounce {
        from { transform: scale(0); opacity: 0; }
        to   { transform: scale(1); opacity: 1; }
      }
      .tri-block {
        transform-origin: 92px 92px;
        animation: triPop 0.4s 1.1s cubic-bezier(0.34,1.6,0.64,1) both;
      }
      @keyframes triPop {
        from { transform: scale(0) rotate(12deg); opacity: 0; }
        to   { transform: scale(1) rotate(0deg);  opacity: 1; }
      }
      .th { opacity: 0; animation: thFade 0.18s ease forwards; }
      .th1 { animation-delay: 1.22s; }
      .th2 { animation-delay: 1.30s; }
      .th3 { animation-delay: 1.38s; }
      .th4 { animation-delay: 1.46s; }
      @keyframes thFade { to { opacity: 0.28; } }
      .hw-icon-group { cursor: pointer; }
      .hw-icon-group:hover .crown {
        animation: float 1.8s ease-in-out infinite;
      }
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-4px); }
      }
      .hw-icon-group:hover .sq-rebel {
        animation: jitter 0.4s ease infinite;
      }
      @keyframes jitter {
        0%   { transform: rotate(-8deg) translate(0,0); }
        33%  { transform: rotate(-6deg) translate(1px,-1px); }
        66%  { transform: rotate(-10deg) translate(-1px,1px); }
        100% { transform: rotate(-8deg) translate(0,0); }
      }
    </style>
    <clipPath id="hw-tri-clip">
      <polygon points="58,92 92,92 92,58"/>
    </clipPath>
    <clipPath id="hw-cp1"><rect x="28" y="76" width="28" height="12"/></clipPath>
    <clipPath id="hw-cp2"><rect x="28" y="62" width="28" height="12"/></clipPath>
    <clipPath id="hw-cp3"><rect x="28" y="48" width="28" height="12"/></clipPath>
    <clipPath id="hw-cp4"><rect x="28" y="34" width="28" height="12"/></clipPath>
    <clipPath id="hw-cp5"><rect x="28" y="20" width="28" height="12"/></clipPath>
  </defs>
  <g class="hw-icon-group">
    <rect x="6" y="6" width="88" height="88" fill="#0d0d0d" opacity="0.2"/>
    <rect x="0" y="0" width="100" height="100" fill="#FF7A00" stroke="#0d0d0d" stroke-width="3"/>
    <g clip-path="url(#hw-cp1)">
      <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="88">
        <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.05s" fill="freeze"/>
        <animate attributeName="y"      from="88" to="76" dur="0.18s" begin="0.05s" fill="freeze"/>
      </rect>
    </g>
    <g clip-path="url(#hw-cp2)">
      <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="74">
        <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.22s" fill="freeze"/>
        <animate attributeName="y"      from="74" to="62" dur="0.18s" begin="0.22s" fill="freeze"/>
      </rect>
    </g>
    <g clip-path="url(#hw-cp3)">
      <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="60">
        <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.39s" fill="freeze"/>
        <animate attributeName="y"      from="60" to="48" dur="0.18s" begin="0.39s" fill="freeze"/>
      </rect>
    </g>
    <g clip-path="url(#hw-cp4)">
      <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="46">
        <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.56s" fill="freeze"/>
        <animate attributeName="y"      from="46" to="34" dur="0.18s" begin="0.56s" fill="freeze"/>
      </rect>
    </g>
    <g clip-path="url(#hw-cp5)">
      <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="32">
        <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.73s" fill="freeze"/>
        <animate attributeName="y"      from="32" to="20" dur="0.18s" begin="0.73s" fill="freeze"/>
      </rect>
    </g>
    <g class="tri-block">
      <polygon points="56,94 94,94 94,56" fill="#FFE600" stroke="#0d0d0d" stroke-width="3" stroke-linejoin="round"/>
      <g clip-path="url(#hw-tri-clip)">
        <line class="th th1" x1="58" y1="92" x2="92" y2="58" stroke="#0d0d0d" stroke-width="2.5"/>
        <line class="th th2" x1="66" y1="94" x2="94" y2="66" stroke="#0d0d0d" stroke-width="2.5"/>
        <line class="th th3" x1="78" y1="94" x2="94" y2="78" stroke="#0d0d0d" stroke-width="2.5"/>
        <line class="th th4" x1="52" y1="92" x2="92" y2="52" stroke="#0d0d0d" stroke-width="2.5"/>
      </g>
    </g>
    <rect class="sq-rebel" x="8" y="18" width="32" height="32"
      fill="#C653FF" stroke="#0d0d0d" stroke-width="3"
      transform="rotate(-8 24 34)"/>
    <circle class="crown" cx="42" cy="18" r="14" fill="#00E5FF" stroke="#0d0d0d" stroke-width="3"/>
    <circle class="crown" cx="42" cy="18" r="7"  fill="none"   stroke="#0d0d0d" stroke-width="2.5"/>
    <circle class="crown" cx="42" cy="18" r="3"  fill="#0d0d0d"/>
    <line class="slash" x1="62" y1="12" x2="14" y2="72"
      stroke="#0d0d0d" stroke-width="3.5" stroke-linecap="round"/>
    <circle class="accent-dot" cx="72" cy="52" r="8" fill="#FF4D6A" stroke="#0d0d0d" stroke-width="2.5"/>
  </g>
</svg>
    </span>
    Hard Won
  </div>

  <div class="lesson-number">{lessonLabel}</div>

  <h1 class="post-title">
    {subtitle ? (
      <>{title} — <span class="underline-accent">{subtitle}</span></>
    ) : (
      <span class="underline-accent">{title}</span>
    )}
  </h1>

  <div class="post-meta">
    <span>{formattedDate}</span>
    <span class="meta-divider">&middot;</span>
    <span>{readTime}</span>
  </div>

  <div class="post-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>
