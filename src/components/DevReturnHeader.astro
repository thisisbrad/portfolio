---
interface Props {
  title: string;
  date: Date;
  readTime: string;
  tags: string[];
  seriesEntry?: number;
  seriesTotal?: number;
}
const { title, date, readTime, tags, seriesEntry = 1, seriesTotal = 10 } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const pips = Array.from({ length: seriesTotal }, (_, i) => {
  if (i < seriesEntry - 1) return 'done';
  if (i === seriesEntry - 1) return 'current';
  return 'empty';
});
---
<div class="post-header">
  <div class="devreturn-series">Dev Return Series</div>
  <div class="section-badge">
    <span class="badge-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 18" width="18" height="18" aria-hidden="true" focusable="false">
        <rect x="1" y="1" width="16" height="16" fill="#00e5ff" stroke="#0d0d0d" stroke-width="1.5"/>
        <polyline points="3,12 9,6 15,12" fill="none" stroke="#0d0d0d" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <polyline points="3,15 9,9 15,15" fill="none" stroke="#0d0d0d" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"/>
      </svg>
    </span> Entry #{seriesEntry} of {seriesTotal}
  </div>
  <h1 class="post-title">{title}</h1>
  <div class="post-meta">
    <span>{formattedDate}</span>
    <span class="meta-divider">&middot;</span>
    <span>{readTime}</span>
  </div>
  <div class="devreturn-progress">
    <span class="dp-label">Progress //</span>
    {pips.map(state => (
      <div class={`dp-pip${state !== 'empty' ? ` ${state}` : ''}`}></div>
    ))}
  </div>
  <div class="post-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>
