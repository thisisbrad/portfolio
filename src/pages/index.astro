---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

// Fetch and sort all posts by date descending
const allPosts = await getCollection('posts');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Show up to 5 most recent posts; first one is featured
const displayPosts = posts.slice(0, 5);
const [featuredPost, ...restPosts] = displayPosts;

const stackItems = [
  'JavaScript',
  'Node.js',
  'React',
  'Next.js',
  'Express',
  'PostgreSQL',
  'MongoDB',
  'Prisma',
  'Astro',
];
---

<BaseLayout title="BRAD.DEV — Building real things, writing it all down." activeLink="writing">
  <div class="site-wrapper">

    <!-- Hero -->
    <section class="hero">
      <span class="hero-eyebrow">// Personal Blog</span>
      <h1>
        Building<br />
        <span class="highlight-cyan">real things</span><br />
        <span class="highlight-coral">writing</span> it<br />
        all down.
      </h1>
      <p class="hero-desc">
        10 years of making things on the web. Now building in public —
        honest logs, hard lessons, and whatever I'm figuring out this week.
      </p>
      <div class="hero-badges">
        <span class="hero-badge yellow">JS &middot; Node &middot; React &middot; Next</span>
        <span class="hero-badge cyan">&#x26A1; Open to Work</span>
        <span class="hero-badge coral">10 Yrs Deep in Code</span>
      </div>
    </section>

    <!-- Stack Section -->
    <section class="stack-section">
      <div class="stack-inner">
        <span class="stack-label">// Stack</span>
        <div class="stack-pills">
          {stackItems.map(item => (
            <span class="stack-pill">{item}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Posts -->
    <section>
      <span class="section-label">// Latest Posts</span>

      <div class="posts-grid">
        {featuredPost && (
          <PostCard post={featuredPost} featured={true} />
        )}
        {restPosts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
