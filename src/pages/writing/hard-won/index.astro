---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';

const posts = (await getCollection('posts'))
  .filter(p => p.data.type === 'hard-won')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postCount = posts.length;
const lessonLabel = `Lesson ${String(postCount).padStart(2, '0')}`;
---

<BaseLayout
  title="Hard Won — BRAD.DEV"
  description="Leadership lessons and hard-earned wisdom. The things I had to learn the hard way."
  type="hard-won"
  activeLink="writing"
>
  <div class="site-wrapper">

    <section class="hw-hero scroll-reveal">
      <div class="hw-hero-text">
        <span class="hw-lesson-label">{lessonLabel}</span>
        <h1 class="hw-title">Hard<br />Won</h1>
        <p class="hw-tagline">Lessons the hard way.</p>
        <span class="hw-count-pill">
          {postCount} {postCount === 1 ? 'lesson' : 'lessons'}
        </span>
      </div>

      <div class="hw-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="160" height="160" overflow="hidden">
          <defs>
            <style>
              .hw-sq-rebel{animation:hwDropIn 0.45s 0.75s cubic-bezier(0.34,1.5,0.64,1) both}
              @keyframes hwDropIn{from{transform:translate(-10px,-10px) rotate(-12deg);opacity:0}to{transform:translate(0,0) rotate(-8deg);opacity:1}}
              .hw-crown{transform-origin:42px 18px;animation:hwCrownPop 0.5s 0.9s cubic-bezier(0.34,1.8,0.64,1) both}
              @keyframes hwCrownPop{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
              .hw-slash{stroke-dasharray:90;stroke-dashoffset:90;animation:hwDrawSlash 0.4s 1.05s cubic-bezier(0.4,0,0.2,1) forwards}
              @keyframes hwDrawSlash{to{stroke-dashoffset:0}}
              .hw-adot{transform-origin:72px 52px;animation:hwDotBounce 0.45s 1.15s cubic-bezier(0.34,2,0.64,1) both}
              @keyframes hwDotBounce{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
              .hw-tri{transform-origin:92px 92px;animation:hwTriPop 0.4s 1.1s cubic-bezier(0.34,1.6,0.64,1) both}
              @keyframes hwTriPop{from{transform:scale(0) rotate(12deg);opacity:0}to{transform:scale(1) rotate(0deg);opacity:1}}
              .hw-th{opacity:0;animation:hwThFade 0.18s ease forwards}
              .hw-th1{animation-delay:1.22s}.hw-th2{animation-delay:1.30s}.hw-th3{animation-delay:1.38s}.hw-th4{animation-delay:1.46s}
              @keyframes hwThFade{to{opacity:0.28}}
              .hw-icon-group{cursor:pointer}
              .hw-icon-group:hover .hw-crown{animation:hwFloat 1.8s ease-in-out infinite}
              @keyframes hwFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
              .hw-icon-group:hover .hw-sq-rebel{animation:hwJitter 0.4s ease infinite}
              @keyframes hwJitter{0%{transform:rotate(-8deg) translate(0,0)}33%{transform:rotate(-6deg) translate(1px,-1px)}66%{transform:rotate(-10deg) translate(-1px,1px)}100%{transform:rotate(-8deg) translate(0,0)}}
            </style>
            <clipPath id="hw-tri-clip"><polygon points="58,92 92,92 92,58"/></clipPath>
            <clipPath id="hw-cp1"><rect x="28" y="76" width="28" height="12"/></clipPath>
            <clipPath id="hw-cp2"><rect x="28" y="62" width="28" height="12"/></clipPath>
            <clipPath id="hw-cp3"><rect x="28" y="48" width="28" height="12"/></clipPath>
            <clipPath id="hw-cp4"><rect x="28" y="34" width="28" height="12"/></clipPath>
            <clipPath id="hw-cp5"><rect x="28" y="20" width="28" height="12"/></clipPath>
          </defs>
          <g class="hw-icon-group">
            <rect x="6" y="6" width="88" height="88" fill="#0d0d0d" opacity="0.2"/>
            <rect x="0" y="0" width="100" height="100" fill="#FF7A00" stroke="#0d0d0d" stroke-width="3"/>
            <g clip-path="url(#hw-cp1)">
              <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="88">
                <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.05s" fill="freeze"/>
                <animate attributeName="y" from="88" to="76" dur="0.18s" begin="0.05s" fill="freeze"/>
              </rect>
            </g>
            <g clip-path="url(#hw-cp2)">
              <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="74">
                <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.22s" fill="freeze"/>
                <animate attributeName="y" from="74" to="62" dur="0.18s" begin="0.22s" fill="freeze"/>
              </rect>
            </g>
            <g clip-path="url(#hw-cp3)">
              <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="60">
                <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.39s" fill="freeze"/>
                <animate attributeName="y" from="60" to="48" dur="0.18s" begin="0.39s" fill="freeze"/>
              </rect>
            </g>
            <g clip-path="url(#hw-cp4)">
              <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="46">
                <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.56s" fill="freeze"/>
                <animate attributeName="y" from="46" to="34" dur="0.18s" begin="0.56s" fill="freeze"/>
              </rect>
            </g>
            <g clip-path="url(#hw-cp5)">
              <rect x="28" width="28" fill="#0d0d0d" stroke="#0d0d0d" stroke-width="2" height="0" y="32">
                <animate attributeName="height" from="0" to="12" dur="0.18s" begin="0.73s" fill="freeze"/>
                <animate attributeName="y" from="32" to="20" dur="0.18s" begin="0.73s" fill="freeze"/>
              </rect>
            </g>
            <g class="hw-tri">
              <polygon points="56,94 94,94 94,56" fill="#FFE600" stroke="#0d0d0d" stroke-width="3" stroke-linejoin="round"/>
              <g clip-path="url(#hw-tri-clip)">
                <line class="hw-th hw-th1" x1="58" y1="92" x2="92" y2="58" stroke="#0d0d0d" stroke-width="2.5"/>
                <line class="hw-th hw-th2" x1="66" y1="94" x2="94" y2="66" stroke="#0d0d0d" stroke-width="2.5"/>
                <line class="hw-th hw-th3" x1="78" y1="94" x2="94" y2="78" stroke="#0d0d0d" stroke-width="2.5"/>
                <line class="hw-th hw-th4" x1="52" y1="92" x2="92" y2="52" stroke="#0d0d0d" stroke-width="2.5"/>
              </g>
            </g>
            <rect class="hw-sq-rebel" x="8" y="18" width="32" height="32" fill="#C653FF" stroke="#0d0d0d" stroke-width="3" transform="rotate(-8 24 34)"/>
            <circle class="hw-crown" cx="42" cy="18" r="14" fill="#00E5FF" stroke="#0d0d0d" stroke-width="3"/>
            <circle class="hw-crown" cx="42" cy="18" r="7"  fill="none" stroke="#0d0d0d" stroke-width="2.5"/>
            <circle class="hw-crown" cx="42" cy="18" r="3"  fill="#0d0d0d"/>
            <line class="hw-slash" x1="62" y1="12" x2="14" y2="72" stroke="#0d0d0d" stroke-width="3.5" stroke-linecap="round"/>
            <circle class="hw-adot" cx="72" cy="52" r="8" fill="#FF4D6A" stroke="#0d0d0d" stroke-width="2.5"/>
          </g>
        </svg>
      </div>

      <!-- Staircase slab bars -->
      <div class="hw-slabs" aria-hidden="true">
        <div class="hw-slab" style="height:36%"></div>
        <div class="hw-slab" style="height:55%"></div>
        <div class="hw-slab" style="height:75%"></div>
        <div class="hw-slab" style="height:92%"></div>
      </div>

      <!-- Watermark lesson count -->
      <div class="hw-watermark" aria-hidden="true">{postCount}</div>
    </section>

    <section class="posts-section scroll-reveal">
      <span class="section-label">// Hard Won</span>
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map(post => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="empty-state">No lessons yet. Stay tuned.</p>
      )}
    </section>

  </div>
</BaseLayout>

<style>
.hw-hero {
  position: relative;
  background: var(--orange);
  border: 4px solid var(--black);
  box-shadow: 10px 10px 0 var(--black);
  padding: 48px 40px 48px 40px;
  margin: 40px 0 52px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: center;
  overflow: hidden;
}

/* Rotated yellow square bleeding off corner */
.hw-hero::after {
  content: '';
  position: absolute;
  bottom: -30px;
  right: -30px;
  width: 110px;
  height: 110px;
  background: var(--yellow);
  border: 3px solid var(--black);
  transform: rotate(18deg);
  opacity: 0.5;
  pointer-events: none;
  z-index: 0;
}

.hw-lesson-label {
  display: inline-block;
  font-family: 'Space Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--black);
  color: var(--orange);
  padding: 4px 12px;
  margin-bottom: 16px;
}

.hw-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(3rem, 9vw, 5.5rem);
  letter-spacing: -0.04em;
  line-height: 0.88;
  color: var(--black);
  margin-bottom: 14px;
}

.hw-tagline {
  font-family: 'Space Mono', monospace;
  font-size: 0.78rem;
  color: rgba(13,13,13,0.6);
  margin-bottom: 20px;
  letter-spacing: 0.02em;
}

.hw-count-pill {
  display: inline-block;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: var(--black);
  color: var(--orange);
  padding: 5px 14px;
  border: 2px solid var(--black);
}

.hw-hero-text {
  position: relative;
  z-index: 1;
}

.hw-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(6deg);
  filter: drop-shadow(5px 5px 0 rgba(13,13,13,0.3));
  transition: transform 0.2s ease;
  position: relative;
  z-index: 1;
}
.hw-icon-wrap:hover {
  transform: rotate(2deg) scale(1.04);
}

/* Staircase slab bars — right edge decoration */
.hw-slabs {
  position: absolute;
  top: 0;
  right: 220px;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  gap: 5px;
  padding-bottom: 0;
  opacity: 0.1;
  pointer-events: none;
  z-index: 0;
}
.hw-slab {
  width: 14px;
  background: var(--black);
  align-self: flex-end;
}

/* Watermark lesson count */
.hw-watermark {
  position: absolute;
  bottom: -20px;
  left: 28px;
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(6rem, 16vw, 10rem);
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 3px rgba(13,13,13,0.1);
  pointer-events: none;
  user-select: none;
  z-index: 0;
}

.posts-section {
  margin-bottom: 80px;
}
.posts-section .section-label {
  margin-bottom: 28px;
  display: inline-block;
}
.posts-grid {
  margin-top: 20px;
}

.empty-state {
  font-family: 'Space Mono', monospace;
  font-size: 0.85rem;
  color: rgba(13,13,13,0.5);
  margin-top: 24px;
  padding: 32px;
  border: 2px dashed rgba(13,13,13,0.2);
  text-align: center;
}

.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.posts-section.scroll-reveal {
  transition-delay: 0.1s;
}

@media (max-width: 640px) {
  .hw-hero {
    grid-template-columns: 1fr;
    padding: 32px 24px;
    margin: 24px 0 40px;
  }
  .hw-icon-wrap { display: none; }
  .hw-slabs { display: none; }
  .hw-watermark { left: 12px; }
  .hw-title { font-size: clamp(2.8rem, 14vw, 4rem); }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
