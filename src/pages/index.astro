---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import profileImg from '../assets/img/AI-Profile-Picture.png';

// Fetch and sort all posts by date descending
const allPosts = await getCollection('posts');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Show up to 5 most recent posts; first one is featured
const displayPosts = posts.slice(0, 5);
const [featuredPost, ...restPosts] = displayPosts;

const stackItems = [
  'JavaScript',
  'Node.js',
  'React',
  'Next.js',
  'Express',
  'PostgreSQL',
  'MongoDB',
  'Prisma',
  'Astro',
];
---

<BaseLayout title="BRAD.DEV — Building real things, writing it all down." activeLink="writing">
  <div class="site-wrapper">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-image-clip">
        <img class="hero-profile" src={profileImg.src} alt="" aria-hidden="true" />
      </div>
      <div class="hero-text">
        <h1>
          <span class="title-line l1">Building</span>
          <span class="title-line l2"><span class="highlight cyan">real things</span></span>
          <span class="title-line l3"><span class="highlight coral">writing</span> it</span>
          <span class="title-line l4">all down.</span>
        </h1>
        <p>
          A developer's working log. Full-stack JS, React, Node, Next.js.
          Posts about the build, the craft, and the search. No fluff — just
          the work.
        </p>
      </div>
      <div class="hero-badge">
        <div class="badge badge-stack">JS &middot; Node &middot; React &middot; SQL</div>
        <div class="badge badge-status">Leadership</div>
        <div class="badge badge-exp">10 Yrs Deep in Code</div>
      </div>
    </section>

    <!-- Stack Section -->
    <section class="stack-section">
      <div class="stack-copy">
        <span class="section-label">// Stack</span>
        <h2 class="stack-heading">Tools I reach<br />for first.</h2>
        <p class="stack-desc">
          Full-stack JavaScript top to bottom. Production-tested, not
          resume-padded.
        </p>
      </div>
      <div class="stack-pills">
        {stackItems.map(item => (
          <span class="stack-pill">{item}</span>
        ))}
      </div>
    </section>

    <!-- Posts -->
    <section>
      <span class="section-label">// Latest Posts</span>

      <div class="posts-grid">
        {featuredPost && (
          <PostCard post={featuredPost} featured={true} />
        )}
        {restPosts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
