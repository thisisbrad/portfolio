---
import BaseLayout from '../../layouts/BaseLayout.astro';

// ── Edit your experiments here ────────────────────────────────────────────────
interface Experiment {
  title: string;
  description: string;
  tags: string[];
  status: 'running' | 'concluded' | 'abandoned';
  hypothesis?: string;
  url?: string;
  repo?: string;
  year: number;
}

const experiments: Experiment[] = [
  {
    title: 'CSS-Only Memphis Patterns',
    description: 'How far can you push CSS background gradients and clip-paths to replicate the Ettore Sottsass aesthetic? Further than expected. This became the visual backbone of this entire site.',
    hypothesis: 'Pure CSS can recreate the key Memphis Group textures without any images.',
    tags: ['CSS', 'Design Systems', 'No-JS'],
    status: 'concluded',
    url: undefined,
    repo: undefined,
    year: 2025,
  },
  {
    title: 'Static Site Performance Budget',
    description: 'Zero client-side JS frameworks, a strict 100kb JS budget per page, and full Lighthouse green. Documenting what\'s possible and what\'s not with a purely static Astro build.',
    hypothesis: 'A feature-rich portfolio site can score 100/100 Lighthouse with no JS framework.',
    tags: ['Astro', 'Performance', 'Static'],
    status: 'running',
    url: undefined,
    repo: undefined,
    year: 2025,
  },
];
// ─────────────────────────────────────────────────────────────────────────────

const statusLabel: Record<Experiment['status'], string> = {
  running: '⟳ Running',
  concluded: '✓ Concluded',
  abandoned: '✗ Abandoned',
};
---

<BaseLayout
  title="Experiments — BRAD.DEV"
  description="Tinkering with no deadline. Hypotheses, explorations, and findings."
  type="projects"
  activeLink="projects"
>
  <div class="site-wrapper">

    <!-- Hero -->
    <section class="exp-hero scroll-reveal">
      <div class="exp-hero-text">
        <a href="/projects" class="exp-back">← All Projects</a>
        <span class="exp-eyebrow">// Tinkering with no deadline.</span>
        <h1 class="exp-title">EXPER<br />IMENTS</h1>
        <div class="exp-meta-row">
          <span class="exp-count-pill">{experiments.length} active</span>
        </div>
      </div>

      <!-- Memphis flask / molecule deco -->
      <div class="exp-deco" aria-hidden="true">
        <div class="flask-body"></div>
        <div class="flask-neck"></div>
        <div class="flask-dot flask-dot--1"></div>
        <div class="flask-dot flask-dot--2"></div>
        <div class="flask-dot flask-dot--3"></div>
      </div>

      <div class="exp-watermark" aria-hidden="true">{experiments.length}</div>
    </section>

    <!-- Experiments list -->
    <section class="experiments-section scroll-reveal">
      <span class="section-label">// Experiments</span>
      <div class="experiments-list">
        {experiments.map((exp, i) => (
          <article class="exp-card">
            <div class="exp-card-index" aria-hidden="true">0{i + 1}</div>

            <div class="exp-card-body">
              <!-- Status + year -->
              <div class="exp-card-top">
                <span class={`exp-status exp-status--${exp.status}`}>
                  {statusLabel[exp.status]}
                </span>
                <span class="exp-year">{exp.year}</span>
              </div>

              <h2 class="exp-title-text">{exp.title}</h2>

              {exp.hypothesis && (
                <blockquote class="exp-hypothesis">
                  <span class="exp-hyp-label">H:</span>
                  {exp.hypothesis}
                </blockquote>
              )}

              <p class="exp-desc">{exp.description}</p>

              <div class="exp-tags">
                {exp.tags.map(t => <span class="tag-pill">{t}</span>)}
              </div>

              {(exp.url || exp.repo) && (
                <div class="exp-links">
                  {exp.url && (
                    <a href={exp.url} class="exp-link exp-link--primary" target="_blank" rel="noopener">View →</a>
                  )}
                  {exp.repo && (
                    <a href={exp.repo} class="exp-link" target="_blank" rel="noopener">Repo ↗</a>
                  )}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
/* ---- Hero ---- */
.exp-hero {
  position: relative;
  background: var(--purple);
  border: 4px solid var(--black);
  box-shadow: 10px 10px 0 var(--black);
  padding: 44px 40px 40px;
  margin: 40px 0 52px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 24px;
}

/* Diagonal stripe texture */
.exp-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    60deg, transparent, transparent 18px,
    rgba(13,13,13,0.06) 18px, rgba(13,13,13,0.06) 20px
  );
  pointer-events: none;
}

.exp-back {
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.04em;
  color: rgba(245,240,232,0.5);
  text-decoration: none;
  display: inline-block;
  margin-bottom: 14px;
  transition: color 0.12s;
}
.exp-back:hover { color: var(--white); }

.exp-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  color: rgba(245,240,232,0.55);
  display: block;
  margin-bottom: 10px;
}

.exp-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(2.6rem, 7.5vw, 5rem);
  letter-spacing: -0.04em;
  line-height: 0.88;
  color: var(--white);
  margin-bottom: 24px;
}

.exp-meta-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.exp-count-pill {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: var(--white);
  color: var(--purple);
  padding: 5px 14px;
  border: 2px solid var(--white);
}

/* Flask Memphis deco */
.exp-deco {
  position: relative;
  width: 100px;
  height: 140px;
  flex-shrink: 0;
  margin-top: 20px;
}

.flask-neck {
  position: absolute;
  width: 26px;
  height: 40px;
  background: var(--white);
  border: 3px solid var(--black);
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
}

.flask-body {
  position: absolute;
  width: 80px;
  height: 70px;
  background: var(--white);
  border: 3px solid var(--black);
  border-radius: 0 0 40px 40px;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  box-shadow: 5px 5px 0 var(--black);
}

.flask-dot {
  position: absolute;
  border-radius: 50%;
  border: 2px solid var(--black);
  z-index: 2;
}

.flask-dot--1 {
  width: 14px;
  height: 14px;
  background: var(--yellow);
  bottom: 30px;
  left: 22px;
}

.flask-dot--2 {
  width: 10px;
  height: 10px;
  background: var(--cyan);
  bottom: 16px;
  right: 22px;
}

.flask-dot--3 {
  width: 8px;
  height: 8px;
  background: var(--orange);
  bottom: 38px;
  right: 28px;
}

.exp-watermark {
  position: absolute;
  bottom: -14px;
  right: 140px;
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(6rem, 16vw, 11rem);
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 3px rgba(245,240,232,0.1);
  pointer-events: none;
  user-select: none;
}

.exp-hero-text {
  position: relative;
  z-index: 1;
}

/* ---- Experiments list ---- */
.experiments-section {
  margin-bottom: 80px;
}

.experiments-section .section-label {
  margin-bottom: 28px;
  display: inline-block;
}

.experiments-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 3px solid var(--black);
  box-shadow: 6px 6px 0 var(--black);
}

/* ---- Experiment card ---- */
.exp-card {
  display: grid;
  grid-template-columns: 80px 1fr;
  border-bottom: 2px solid var(--black);
  background: var(--white);
  cursor: crosshair;
  transition: background 0.15s;
}

.exp-card:last-child {
  border-bottom: none;
}

.exp-card:hover {
  background: color-mix(in srgb, var(--purple) 5%, var(--white));
}

/* Index column */
.exp-card-index {
  border-right: 3px solid var(--black);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 28px 0 28px;
  font-family: 'Archivo Black', sans-serif;
  font-size: 2rem;
  color: transparent;
  -webkit-text-stroke: 2px rgba(13,13,13,0.15);
  user-select: none;
}

/* Right body */
.exp-card-body {
  padding: 28px 32px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.exp-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.exp-status {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 8px;
  border: 1.5px solid currentColor;
}

.exp-status--running {
  color: var(--orange);
  background: rgba(255, 122, 0, 0.08);
}

.exp-status--concluded {
  color: #1a7a00;
  background: rgba(57, 255, 20, 0.1);
}

.exp-status--abandoned {
  color: rgba(13,13,13,0.4);
}

.exp-year {
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  color: rgba(13,13,13,0.4);
}

.exp-title-text {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: 1.4rem;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--black);
}

.exp-hypothesis {
  font-family: 'Lora', serif;
  font-style: italic;
  font-size: 0.88rem;
  line-height: 1.55;
  color: rgba(13,13,13,0.65);
  padding: 10px 16px;
  border-left: 4px solid var(--purple);
  background: color-mix(in srgb, var(--purple) 5%, var(--white));
}

.exp-hyp-label {
  font-family: 'Space Mono', monospace;
  font-style: normal;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--purple);
  margin-right: 8px;
}

.exp-desc {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.87rem;
  line-height: 1.6;
  color: rgba(13,13,13,0.7);
}

.exp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tag-pill {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.04em;
  padding: 3px 8px;
  border: 1.5px solid rgba(13,13,13,0.25);
  color: rgba(13,13,13,0.6);
  background: color-mix(in srgb, var(--purple) 4%, transparent);
}

.exp-links {
  display: flex;
  gap: 10px;
}

.exp-link {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 6px 14px;
  border: 2px solid var(--black);
  color: var(--black);
  background: transparent;
  box-shadow: 3px 3px 0 var(--black);
  transition: transform 0.1s, box-shadow 0.1s;
  cursor: crosshair;
}

.exp-link:hover {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--black);
}

.exp-link--primary {
  background: var(--purple);
  color: var(--white);
}

/* ---- Scroll reveal ---- */
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.experiments-section.scroll-reveal { transition-delay: 0.1s; }

/* ---- Responsive ---- */
@media (max-width: 640px) {
  .exp-hero {
    grid-template-columns: 1fr;
    padding: 32px 24px;
    margin: 24px 0 40px;
  }
  .exp-deco { display: none; }
  .exp-watermark { right: 16px; }
  .exp-card {
    grid-template-columns: 1fr;
  }
  .exp-card-index {
    border-right: none;
    border-bottom: 2px solid var(--black);
    padding: 12px 28px;
    justify-content: flex-start;
    font-size: 1.4rem;
  }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
