---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    label: 'Side Projects',
    tagline: 'Things built for fun, from scratch.',
    href: '/projects/side',
    color: '#ffe600',
    dark: '#0d0d0d',
    count: 3,
    glyph: `<svg viewBox="0 0 100 100" width="100%" height="100%" aria-hidden="true">
      <rect x="10" y="10" width="36" height="36" fill="currentColor" opacity="0.9"/>
      <rect x="54" y="10" width="36" height="36" fill="none" stroke="currentColor" stroke-width="4"/>
      <rect x="10" y="54" width="36" height="36" fill="none" stroke="currentColor" stroke-width="4"/>
      <rect x="54" y="54" width="36" height="36" fill="currentColor" opacity="0.4"/>
      <line x1="28" y1="10" x2="28" y2="90" stroke="currentColor" stroke-width="1.5" opacity="0.2"/>
      <line x1="10" y1="28" x2="90" y2="28" stroke="currentColor" stroke-width="1.5" opacity="0.2"/>
    </svg>`,
  },
  {
    label: 'Open Source',
    tagline: 'Code that lives in the open.',
    href: '/projects/open-source',
    color: '#39ff14',
    dark: '#0d0d0d',
    count: 2,
    glyph: `<svg viewBox="0 0 100 100" width="100%" height="100%" aria-hidden="true">
      <circle cx="50" cy="20" r="12" fill="currentColor"/>
      <circle cx="20" cy="72" r="12" fill="currentColor"/>
      <circle cx="80" cy="72" r="12" fill="currentColor"/>
      <line x1="50" y1="32" x2="20" y2="60" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
      <line x1="50" y1="32" x2="80" y2="60" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
      <line x1="28" y1="68" x2="68" y2="68" stroke="currentColor" stroke-width="3" stroke-dasharray="6 4" opacity="0.4"/>
    </svg>`,
  },
  {
    label: 'Experiments',
    tagline: 'Tinkering with no deadline.',
    href: '/projects/experiments',
    color: '#c653ff',
    dark: '#f5f0e8',
    count: 2,
    glyph: `<svg viewBox="0 0 100 100" width="100%" height="100%" aria-hidden="true">
      <rect x="38" y="8" width="24" height="28" fill="currentColor" opacity="0.9" rx="2"/>
      <polygon points="16,90 84,90 62,36 38,36" fill="currentColor" opacity="0.7"/>
      <polygon points="16,90 84,90 62,36 38,36" fill="none" stroke="currentColor" stroke-width="3"/>
      <circle cx="36" cy="70" r="5" fill="currentColor" opacity="0.9"/>
      <circle cx="58" cy="78" r="3" fill="currentColor" opacity="0.6"/>
      <circle cx="70" cy="65" r="4" fill="currentColor" opacity="0.5"/>
    </svg>`,
  },
];

const totalProjects = categories.reduce((sum, c) => sum + c.count, 0);
---

<BaseLayout
  title="Projects — BRAD.DEV"
  description="Things built, shipped, contributed, and experimented with. A decade of side projects, open source, and tinkering."
  type="projects"
  activeLink="projects"
>
  <div class="site-wrapper">

    <!-- Hero -->
    <section class="proj-hero scroll-reveal">

      <!-- Memphis floating shapes -->
      <div class="shape-cluster" aria-hidden="true">
        <div class="geo geo-sq"></div>
        <div class="geo geo-circle"></div>
        <div class="geo geo-tri"></div>
        <div class="geo geo-dot"></div>
      </div>

      <div class="proj-hero-content">
        <span class="proj-eyebrow">// Things built. Things broken. Things shipped.</span>
        <h1 class="proj-title">PROJ<br />ECTS</h1>
        <div class="proj-hero-meta">
          <span class="proj-count-pill">{totalProjects} total</span>
          <span class="proj-hero-sub">across {categories.length} categories</span>
        </div>
      </div>

      <div class="proj-watermark" aria-hidden="true">{totalProjects}</div>
    </section>

    <!-- Category Grid -->
    <section class="categories-section scroll-reveal">
      <span class="section-label">// Browse by type</span>

      <div class="categories-grid">
        {categories.map((cat, i) => (
          <a
            class="cat-card"
            href={cat.href}
            style={`--cat-color:${cat.color};--cat-dark:${cat.dark}`}
          >
            <!-- Diagonal stripe overlay -->
            <div class="cat-stripe" aria-hidden="true"></div>

            <div class="cat-icon" aria-hidden="true" set:html={cat.glyph}></div>

            <div class="cat-body">
              <h2 class="cat-name">{cat.label}</h2>
              <p class="cat-tagline">{cat.tagline}</p>
            </div>

            <div class="cat-footer">
              <span class="cat-count">{cat.count} {cat.count === 1 ? 'project' : 'projects'}</span>
              <span class="cat-arrow">→</span>
            </div>

            <!-- Index badge -->
            <span class="cat-index" aria-hidden="true">0{i + 1}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="proj-cta scroll-reveal">
      <div class="cta-inner">
        <span class="cta-label">// Have a project in mind?</span>
        <a href="/about#connect" class="cta-btn">Let's talk →</a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
/* ---- Hero ---- */
.proj-hero {
  position: relative;
  background: var(--black);
  border: 4px solid var(--black);
  box-shadow: 10px 10px 0 var(--black);
  padding: 52px 44px 48px;
  margin: 40px 0 52px;
  overflow: hidden;
  min-height: 260px;
  display: flex;
  align-items: flex-end;
}

/* Memphis floating geometry */
.shape-cluster {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.geo {
  position: absolute;
}

.geo-sq {
  width: 110px;
  height: 110px;
  background: var(--yellow);
  border: 4px solid rgba(255,255,255,0.15);
  top: -24px;
  right: 180px;
  transform: rotate(18deg);
  opacity: 0.85;
}

.geo-circle {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--cyan);
  top: 20px;
  right: 60px;
  opacity: 0.75;
}

.geo-tri {
  width: 0;
  height: 0;
  border-left: 44px solid transparent;
  border-right: 44px solid transparent;
  border-bottom: 76px solid var(--orange);
  bottom: 16px;
  right: 240px;
  opacity: 0.6;
}

.geo-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--purple);
  bottom: 28px;
  right: 100px;
  opacity: 0.9;
}

.proj-hero-content {
  position: relative;
  z-index: 2;
}

.proj-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  color: rgba(245, 240, 232, 0.5);
  display: block;
  margin-bottom: 10px;
}

.proj-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(3.4rem, 10vw, 6.5rem);
  letter-spacing: -0.04em;
  line-height: 0.88;
  color: var(--white);
  margin-bottom: 24px;
}

/* Yellow highlight on first word */
.proj-title span {
  color: var(--yellow);
}

.proj-hero-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.proj-count-pill {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: var(--yellow);
  color: var(--black);
  padding: 5px 14px;
  border: 2px solid var(--yellow);
}

.proj-hero-sub {
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  color: rgba(245, 240, 232, 0.4);
}

/* Ghost watermark */
.proj-watermark {
  position: absolute;
  bottom: -20px;
  right: 340px;
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(6rem, 18vw, 13rem);
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 3px rgba(245, 240, 232, 0.07);
  pointer-events: none;
  user-select: none;
  z-index: 1;
}

/* ---- Categories section ---- */
.categories-section {
  margin-bottom: 60px;
}

.categories-section .section-label {
  margin-bottom: 28px;
  display: inline-block;
}

.categories-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 4px solid var(--black);
  box-shadow: 8px 8px 0 var(--black);
}

/* ---- Category card ---- */
.cat-card {
  position: relative;
  background: var(--cat-color);
  border-right: 3px solid var(--black);
  padding: 32px 28px 28px;
  display: flex;
  flex-direction: column;
  gap: 0;
  text-decoration: none;
  color: var(--cat-dark);
  overflow: hidden;
  cursor: crosshair;
  transition: filter 0.15s;
  min-height: 320px;
}

.cat-card:last-child {
  border-right: none;
}

.cat-card:hover {
  filter: brightness(1.06);
}

.cat-card:hover .cat-arrow {
  transform: translateX(4px);
}

/* Diagonal stripe overlay texture */
.cat-stripe {
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    135deg,
    transparent,
    transparent 18px,
    rgba(13, 13, 13, 0.04) 18px,
    rgba(13, 13, 13, 0.04) 20px
  );
  pointer-events: none;
}

/* SVG icon */
.cat-icon {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
  margin-bottom: 20px;
  color: var(--cat-dark);
}

.cat-icon svg {
  display: block;
  width: 100%;
  height: 100%;
}

.cat-body {
  flex: 1;
}

.cat-name {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(1.35rem, 2.5vw, 1.75rem);
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--cat-dark);
  margin-bottom: 10px;
}

.cat-tagline {
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  line-height: 1.5;
  color: color-mix(in srgb, var(--cat-dark) 65%, transparent);
}

.cat-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24px;
  padding-top: 16px;
  border-top: 2.5px solid color-mix(in srgb, var(--cat-dark) 20%, transparent);
}

.cat-count {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: var(--cat-dark);
  color: var(--cat-color);
  padding: 4px 10px;
}

.cat-arrow {
  font-family: 'Space Mono', monospace;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--cat-dark);
  transition: transform 0.15s;
}

/* Oversized index number watermark */
.cat-index {
  position: absolute;
  bottom: -10px;
  right: 12px;
  font-family: 'Archivo Black', sans-serif;
  font-size: 5rem;
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 2px color-mix(in srgb, var(--cat-dark) 12%, transparent);
  pointer-events: none;
  user-select: none;
}

/* ---- CTA bar ---- */
.proj-cta {
  margin-bottom: 80px;
}

.cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 28px 32px;
  border: 3px solid var(--black);
  box-shadow: 6px 6px 0 var(--black);
  background: var(--black);
  flex-wrap: wrap;
}

.cta-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.8rem;
  letter-spacing: 0.04em;
  color: rgba(245, 240, 232, 0.6);
}

.cta-btn {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  text-decoration: none;
  color: var(--black);
  background: var(--cyan);
  padding: 10px 24px;
  border: 2.5px solid var(--cyan);
  box-shadow: 4px 4px 0 var(--cyan);
  transition: transform 0.1s, box-shadow 0.1s;
  cursor: crosshair;
  flex-shrink: 0;
}

.cta-btn:hover {
  transform: translate(-2px, -2px);
  box-shadow: 6px 6px 0 var(--cyan);
}

/* ---- Scroll reveal ---- */
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.categories-section.scroll-reveal { transition-delay: 0.1s; }
.proj-cta.scroll-reveal { transition-delay: 0.18s; }

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .categories-grid {
    grid-template-columns: 1fr;
  }
  .cat-card {
    border-right: none;
    border-bottom: 3px solid var(--black);
    min-height: 200px;
  }
  .cat-card:last-child {
    border-bottom: none;
  }
}

@media (max-width: 640px) {
  .proj-hero {
    padding: 36px 24px 36px;
    margin: 24px 0 40px;
    min-height: 200px;
  }
  .geo-sq { width: 70px; height: 70px; right: 100px; }
  .geo-circle { width: 50px; height: 50px; right: 32px; top: 16px; }
  .geo-tri { display: none; }
  .proj-watermark { right: 160px; }
  .cta-inner { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
