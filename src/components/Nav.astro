---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  activeLink?: 'writing' | 'projects' | 'stack' | 'about';
  wide?: boolean;
}
const { activeLink, wide = false } = Astro.props;

type PostType = 'build-log' | 'the-search' | 'dev-return' | 'hard-won';

const allPosts = await getCollection('posts');
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentByType: Record<PostType, CollectionEntry<'posts'>[]> = {
  'build-log':  sorted.filter(p => p.data.type === 'build-log').slice(0, 2),
  'the-search': sorted.filter(p => p.data.type === 'the-search').slice(0, 2),
  'dev-return': sorted.filter(p => p.data.type === 'dev-return').slice(0, 2),
  'hard-won':   sorted.filter(p => p.data.type === 'hard-won').slice(0, 2),
};

// Black-line icons at final animation state — no background rect, currentColor for all
// strokes/fills (inherits each column's --col-dark), all elements at their post-animation
// opacity/position (strokes fully drawn, no elements scaled to zero or hidden).
const blIcon = `<svg viewBox="0 0 100 100" width="100%" height="100%" overflow="hidden" aria-hidden="true"><defs><clipPath id="mn-bl-clip"><rect x="8" y="8" width="84" height="84"/></clipPath></defs><g clip-path="url(#mn-bl-clip)" opacity="0.18"><line x1="-5" y1="35" x2="55" y2="-5" stroke="currentColor" stroke-width="2"/><line x1="-5" y1="58" x2="78" y2="-5" stroke="currentColor" stroke-width="2"/><line x1="-5" y1="82" x2="95" y2="-5" stroke="currentColor" stroke-width="2"/><line x1="8" y1="96" x2="96" y2="8" stroke="currentColor" stroke-width="2"/><line x1="32" y1="96" x2="96" y2="32" stroke="currentColor" stroke-width="2"/><line x1="58" y1="96" x2="96" y2="58" stroke="currentColor" stroke-width="2"/></g><rect x="56" y="56" width="34" height="34" fill="currentColor"/><polyline points="8,62 20,48 32,62 44,48 56,62 68,48 80,62 92,50" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="78" cy="22" r="9" fill="currentColor"/></svg>`;
const tsIcon = `<svg viewBox="0 0 100 100" width="100%" height="100%" aria-hidden="true"><circle cx="50" cy="50" r="36" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="50" cy="50" r="22" fill="none" stroke="currentColor" stroke-width="4"/><circle cx="50" cy="50" r="10" fill="currentColor"/><circle cx="50" cy="50" r="42" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="6 10" opacity="0.4"/><line x1="50" y1="4" x2="50" y2="14" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><line x1="50" y1="86" x2="50" y2="96" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><line x1="4" y1="50" x2="14" y2="50" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><line x1="86" y1="50" x2="96" y2="50" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>`;
const drIcon = `<svg viewBox="0 0 100 100" width="100%" height="100%" aria-hidden="true"><rect x="8" y="8" width="16" height="10" fill="currentColor"/><rect x="30" y="8" width="16" height="10" fill="currentColor"/><rect x="52" y="8" width="16" height="10" fill="currentColor"/><rect x="74" y="8" width="16" height="10" fill="currentColor"/><polyline points="12,72 50,34 88,72" fill="none" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/><polyline points="12,88 50,50 88,88" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" opacity="0.25"/><circle cx="18" cy="82" r="7" fill="currentColor"/></svg>`;
const hwIcon = `<svg viewBox="0 0 100 100" width="100%" height="100%" overflow="hidden" aria-hidden="true"><rect x="28" y="76" width="28" height="12" fill="currentColor"/><rect x="28" y="62" width="28" height="12" fill="currentColor"/><rect x="28" y="48" width="28" height="12" fill="currentColor"/><rect x="28" y="34" width="28" height="12" fill="currentColor"/><rect x="28" y="20" width="28" height="12" fill="currentColor"/><polygon points="56,94 94,94 94,56" fill="currentColor" opacity="0.85"/><rect x="8" y="18" width="32" height="32" fill="currentColor" opacity="0.25" transform="rotate(-8 24 34)"/><circle cx="42" cy="18" r="14" fill="none" stroke="currentColor" stroke-width="3"/><circle cx="42" cy="18" r="7" fill="none" stroke="currentColor" stroke-width="2.5"/><circle cx="42" cy="18" r="3" fill="currentColor"/><line x1="62" y1="12" x2="14" y2="72" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>`;

const writingTypes: Array<{
  key: PostType;
  label: string;
  color: string;
  dark: string;
  icon: string;
  tagline: string;
  href: string;
}> = [
  { key: 'build-log',  label: 'Build Log',  color: '#ffe600', dark: '#0d0d0d', icon: blIcon, tagline: 'The work, step by step.',    href: '/writing/build-log' },
  { key: 'the-search', label: 'The Search', color: '#ff4d6a', dark: '#f5f0e8', icon: tsIcon, tagline: 'Job hunting, raw and real.', href: '/writing/the-search' },
  { key: 'dev-return', label: 'Dev Return', color: '#00e5ff', dark: '#0d0d0d', icon: drIcon, tagline: 'Coming back to the craft.',  href: '/writing/dev-return' },
  { key: 'hard-won',   label: 'Hard Won',   color: '#ff7a00', dark: '#0d0d0d', icon: hwIcon, tagline: 'Lessons the hard way.',      href: '/writing/hard-won' },
];

const projectTypes = [
  { label: 'Side Projects', href: '/projects/side' },
  { label: 'Open Source',   href: '/projects/open-source' },
  { label: 'Experiments',   href: '/projects/experiments' },
];
---

<nav>
  <div class={`nav-inner${wide ? ' nav-inner--wide' : ''}`}>
    <a class="nav-logo" href="/">THISISBRAD.DEV</a>

    <button class="mobile-menu-btn" aria-label="Open menu" aria-controls="mobile-drawer" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links">

      <!-- Writing — mega menu -->
      <li class="nav-item has-mega">
        <a
          href="/"
          class={`nav-trigger${activeLink === 'writing' ? ' active' : ''}`}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Writing <span class="nav-chevron">▾</span>
        </a>

        <div class="mega-panel" role="region" aria-label="Writing categories">
          <div class="mega-inner">
            {writingTypes.map((type) => (
              <div
                class="mega-col"
                style={`--col-accent:${type.color};--col-dark:${type.dark}`}
              >
                <a class="mega-col-head" href={type.href}>
                  <span class="mega-symbol" set:html={type.icon}></span>
                  <span class="mega-type-name">{type.label}</span>
                </a>
                <p class="mega-tagline">{type.tagline}</p>

                {recentByType[type.key].length > 0 && (
                  <ul class="mega-posts">
                    {recentByType[type.key].map(post => (
                      <li>
                        <a href={`/posts/${post.id.replace(/\.(md|mdx)$/, '')}`} class="mega-post-link">
                          <span class="mega-post-arrow">›</span>
                          <span>{post.data.title}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}

                <a href={type.href} class="mega-all-link">
                  All {type.label} →
                </a>
              </div>
            ))}
          </div>
        </div>
      </li>

      <!-- Projects — simple dropdown -->
      <li class="nav-item has-dropdown">
        <a
          href="/projects"
          class={`nav-trigger${activeLink === 'projects' ? ' active' : ''}`}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Projects <span class="nav-chevron">▾</span>
        </a>

        <div class="dropdown-panel" role="region" aria-label="Project categories">
          <ul class="dropdown-list">
            {projectTypes.map(pt => (
              <li>
                <a href={pt.href} class="dropdown-link">
                  <span class="dropdown-bullet">›</span> {pt.label}
                </a>
              </li>
            ))}
            <li class="dropdown-sep"></li>
            <li>
              <a href="/projects" class="dropdown-link dropdown-link--all">
                All Projects →
              </a>
            </li>
          </ul>
        </div>
      </li>

      <!-- Plain links -->
      <!-- <li>
        <a href="/stack" class={activeLink === 'stack' ? 'active' : ''}>Stack</a>
      </li> -->
      <li>
        <a href="/about" class={activeLink === 'about' ? 'active' : ''}>About</a>
      </li>
      <li>
        <a href="/rss.xml" aria-label="RSS feed">RSS</a>
      </li>

    </ul>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">

    <!-- Writing section header -->
    <a class="mobile-drawer-section-head" href="/">
      <span class="mobile-drawer-section-label">Writing</span>
      <span class="mobile-drawer-section-arrow">→</span>
    </a>

    <!-- Writing sub-sections -->
    {writingTypes.map(type => (
      <a
        class="mobile-drawer-link"
        href={type.href}
        style={`--col-accent:${type.color};--col-dark:${type.dark}`}
      >
        <span class="mobile-drawer-symbol" set:html={type.icon}></span>
        <span class="mobile-drawer-text">
          <span class="mobile-drawer-label">{type.label}</span>
          <span class="mobile-drawer-tagline">{type.tagline}</span>
        </span>
        <span class="mobile-drawer-arrow">→</span>
      </a>
    ))}

    <!-- Projects section header -->
    <a class="mobile-drawer-section-head mobile-drawer-section-head--projects" href="/projects">
      <span class="mobile-drawer-section-label">Projects</span>
      <span class="mobile-drawer-section-arrow">→</span>
    </a>

    <!-- Project sub-sections -->
    {projectTypes.map(pt => (
      <a class="mobile-drawer-link mobile-drawer-link--project" href={pt.href}>
        <span class="mobile-drawer-proj-bullet">◆</span>
        <span class="mobile-drawer-text">
          <span class="mobile-drawer-label">{pt.label}</span>
        </span>
        <span class="mobile-drawer-arrow" style="color: var(--yellow);">→</span>
      </a>
    ))}

    <!-- About link -->
    <a class="mobile-drawer-about" href="/about">
      <span class="mobile-drawer-about-glyph">◈</span>
      <span class="mobile-drawer-text">
        <span class="mobile-drawer-label">About</span>
        <span class="mobile-drawer-tagline">The person behind the work.</span>
      </span>
      <span class="mobile-drawer-arrow" style="color: var(--cyan);">→</span>
    </a>

  </div>
</nav>

<style>
/* ----------------------------------------------------------------
   RESET — global .nav-links a styles bleed into panels; undo them
   ---------------------------------------------------------------- */
.mega-panel a,
.dropdown-panel a {
  border: none;
  background: transparent;
  box-shadow: none;
  padding: 0;
  transform: none;
  color: var(--black);
  display: flex;
  cursor: crosshair;
}

.mega-panel a:hover,
.dropdown-panel a:hover {
  background: transparent;
  box-shadow: none;
  transform: none;
  color: var(--black);
}

/* ----------------------------------------------------------------
   NAV ITEM — shared wrapper
   ---------------------------------------------------------------- */
.nav-item {
  list-style: none;
}

/* The trigger links (Writing, Projects) inherit .nav-links a styling
   from global.css; we only need to handle the chevron and open states. */
.nav-trigger {
  display: inline-flex !important;
  align-items: center;
  gap: 5px;
}

.nav-chevron {
  font-size: 0.55rem;
  line-height: 1;
  transition: transform 0.18s ease;
  display: inline-block;
}

.has-mega.is-open .nav-chevron,
.has-dropdown.is-open .nav-chevron {
  transform: rotate(180deg);
}

/* ----------------------------------------------------------------
   MEGA PANEL — full nav-width writing menu
   ---------------------------------------------------------------- */
.mega-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 100%;
  background: var(--white);
  border-left: 4px solid var(--black);
  border-right: 4px solid var(--black);
  border-bottom: 4px solid var(--black);
  z-index: 200;

  /* hidden */
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px);
  transition:
    opacity 0.2s ease,
    transform 0.2s ease,
    visibility 0s linear 0.2s;
  pointer-events: none;
}

.has-mega.is-open .mega-panel {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  transition:
    opacity 0.2s ease,
    transform 0.2s ease,
    visibility 0s linear 0s;
  pointer-events: auto;
}

/* 4-column grid */
.mega-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

/* Each column */
.mega-col {
  padding: 26px 22px 22px;
  border-right: 3px solid var(--black);
  border-top: 7px solid var(--col-accent);
  display: flex;
  flex-direction: column;
  transition: background 0.15s;
}

.mega-col:last-child {
  border-right: none;
}

.mega-col:hover {
  background: color-mix(in srgb, var(--col-accent) 8%, var(--white));
}

/* Column header: symbol box + type name */
.mega-col-head {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: var(--black);
  margin-bottom: 6px;
}

.mega-col-head:hover .mega-symbol {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--black);
}

.mega-col-head:hover .mega-type-name {
  text-decoration-line: underline;
  text-decoration-style: wavy;
  text-decoration-color: var(--col-accent);
  text-decoration-thickness: 4px;
  text-underline-offset: 4px;
}

.mega-symbol {
  background: var(--col-accent);
  color: var(--col-dark);
  width: 46px;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--black);
  box-shadow: 3px 3px 0 var(--black);
  flex-shrink: 0;
  transition: transform 0.12s, box-shadow 0.12s;
  padding: 5px;
  overflow: hidden;
}

.mega-symbol svg {
  display: block;
  width: 100%;
  height: 100%;
}

.mega-type-name {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: -0.025em;
  line-height: 1;
  color: var(--black);
}

.mega-tagline {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: rgba(13, 13, 13, 0.5);
  margin-bottom: 14px;
  padding-left: 58px; /* symbol(46) + gap(12) */
  line-height: 1.4;
}

/* Recent posts */
.mega-posts {
  list-style: none;
  border-top: 2px solid rgba(13, 13, 13, 0.1);
  padding-top: 10px;
  margin-bottom: 14px;
  flex: 1;
}

.mega-post-link {
  display: flex;
  gap: 6px;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  text-decoration: none;
  color: var(--black);
  padding: 5px 0;
  border-bottom: 1.5px solid transparent;
  transition: border-color 0.12s;
  line-height: 1.35;
  cursor: crosshair;
}

.mega-post-link:hover {
  border-bottom: 1.5px solid var(--col-accent);
}

.mega-post-arrow {
  color: var(--col-accent);
  flex-shrink: 0;
  font-weight: 800;
  font-size: 0.9rem;
}

/* "All X →" footer link */
.mega-all-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  text-decoration: none;
  color: var(--col-dark);
  background: var(--col-accent);
  padding: 5px 12px;
  border: 2.5px solid var(--black);
  box-shadow: 3px 3px 0 var(--black);
  transition: transform 0.1s, box-shadow 0.1s;
  cursor: crosshair;
  align-self: flex-start;
  margin-top: auto;
}

.mega-all-link:hover {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--black);
  background: var(--col-accent);
  color: var(--col-dark);
}

/* ----------------------------------------------------------------
   DROPDOWN PANEL — Projects
   ---------------------------------------------------------------- */
.has-dropdown {
  position: relative;
}

.dropdown-panel {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 210px;
  background: var(--white);
  border: 3px solid var(--black);
  box-shadow: 6px 6px 0 var(--black);
  z-index: 200;

  /* hidden */
  opacity: 0;
  visibility: hidden;
  transform: translateY(-6px);
  transition:
    opacity 0.15s ease,
    transform 0.15s ease,
    visibility 0s linear 0.15s;
  pointer-events: none;
}

/* Invisible hover bridge — fills the gap between trigger and panel */
.dropdown-panel::before {
  content: '';
  position: absolute;
  top: -8px;
  left: 0;
  right: 0;
  height: 8px;
}

.has-dropdown.is-open .dropdown-panel {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  transition:
    opacity 0.15s ease,
    transform 0.15s ease,
    visibility 0s linear 0s;
  pointer-events: auto;
}

.dropdown-list {
  list-style: none;
}

.dropdown-link {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  text-decoration: none;
  color: var(--black);
  padding: 11px 16px;
  border-bottom: 2px solid rgba(13, 13, 13, 0.15);
  transition: background 0.12s;
  cursor: crosshair;
}

.dropdown-list li:last-child .dropdown-link {
  border-bottom: none;
}

.dropdown-link:hover {
  background: var(--cyan);
  color: var(--black);
}

.dropdown-bullet {
  color: var(--yellow);
  font-weight: 800;
  font-size: 1rem;
}

.dropdown-sep {
  height: 3px;
  background: var(--black);
}

.dropdown-link--all {
  font-style: italic;
  background: var(--black);
  color: var(--yellow);
  border-bottom: none;
}

.dropdown-link--all:hover {
  background: var(--black);
  color: var(--cyan);
}

/* ================================================================
   MOBILE-FIRST: hamburger button
   Base = mobile (visible). Desktop override hides it.
   ================================================================ */
.mobile-menu-btn {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  background: none;
  border: 2px solid var(--black);
  cursor: crosshair;
  padding: 6px;
  flex-shrink: 0;
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.mobile-menu-btn:hover {
  transform: translate(-2px, -2px);
  box-shadow: 3px 3px 0 var(--black);
}

.mobile-menu-btn span {
  display: block;
  height: 2px;
  background: var(--black);
  transition: transform 0.2s ease, opacity 0.2s ease;
  transform-origin: center;
}

/* X state when open */
.mobile-menu-btn[aria-expanded="true"] span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.mobile-menu-btn[aria-expanded="true"] span:nth-child(2) {
  opacity: 0;
}
.mobile-menu-btn[aria-expanded="true"] span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* Desktop: hide hamburger, show nav links */
@media (min-width: 641px) {
  .mobile-menu-btn {
    display: none;
  }

  .nav-links {
    display: flex !important; /* override any inherited hidden state */
  }
}

/* Mobile: hide desktop nav links */
@media (max-width: 640px) {
  .nav-links {
    display: none;
  }
}

/* ================================================================
   MOBILE-FIRST: mobile drawer
   Base = mobile (rendered, collapsed). Desktop override hides it.
   ================================================================ */
.mobile-drawer {
  display: flex;
  flex-direction: column;
  background: var(--white);
  border-top: 3px solid var(--black);
  border-bottom: 3px solid var(--black);

  /* collapsed by default */
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.mobile-drawer.is-open {
  /* writing-head(~52) + 4 writing(~60ea=240) + projects-head(~52) + 3 proj(~52ea=156) + about(~60) + buffer */
  max-height: 700px;
}

/* Desktop: drawer is fully removed from flow */
@media (min-width: 641px) {
  .mobile-drawer {
    display: none;
  }
}

/* ----------------------------------------------------------------
   Writing section header inside drawer
   ---------------------------------------------------------------- */
.mobile-drawer-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 20px 10px 20px;
  text-decoration: none;
  color: var(--black);
  background: var(--black);
  border-bottom: 3px solid var(--black);
  transition: background 0.12s;
  cursor: crosshair;
}

.mobile-drawer-section-head:hover {
  background: #1a1a1a;
}

.mobile-drawer-section-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--yellow);
}

.mobile-drawer-section-arrow {
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  color: var(--yellow);
  opacity: 0.7;
}

/* ----------------------------------------------------------------
   Writing sub-section links
   ---------------------------------------------------------------- */
.mobile-drawer-link {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 20px;
  border-bottom: 2px solid rgba(13, 13, 13, 0.1);
  text-decoration: none;
  color: var(--black);
  border-left: 5px solid var(--col-accent);
  transition: background 0.12s;
  cursor: crosshair;
}

.mobile-drawer-link:hover {
  background: color-mix(in srgb, var(--col-accent) 12%, var(--white));
}

.mobile-drawer-symbol {
  background: var(--col-accent);
  color: var(--col-dark);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--black);
  flex-shrink: 0;
  padding: 4px;
}

.mobile-drawer-symbol svg {
  display: block;
  width: 100%;
  height: 100%;
}

.mobile-drawer-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex: 1;
  min-width: 0;
}

.mobile-drawer-label {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: 0.95rem;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--black);
}

.mobile-drawer-tagline {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  color: rgba(13, 13, 13, 0.5);
  line-height: 1.3;
