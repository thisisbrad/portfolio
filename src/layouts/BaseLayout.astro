---
import MemphisStripe from '../components/MemphisStripe.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  type?: 'build-log' | 'the-search' | 'dev-return';
  activeLink?: 'writing' | 'projects' | 'stack' | 'about';
}

const { title, description = 'A personal developer blog by Brad.', type, activeLink } = Astro.props;

const themeClassMap: Record<string, string> = {
  'build-log':  'theme-buildlog',
  'the-search': 'theme-search',
  'dev-return': 'theme-devreturn',
};
const themeClass = type ? (themeClassMap[type] ?? '') : '';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Space+Grotesk:wght@400;500;600;700&family=Archivo+Black&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,600;1,400;1,600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={themeClass}>
    <!-- Fixed decorative background shapes -->
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
    <div class="shape shape-5"></div>

    <!-- Top stripe -->
    <MemphisStripe />

    <!-- Navigation -->
    <Nav activeLink={activeLink} />

    <!-- Page content -->
    <slot />

    <!-- Footer -->
    <Footer />

    <!-- Bottom stripe -->
    <MemphisStripe />
  </body>
</html>
