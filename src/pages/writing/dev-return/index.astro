---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';

const posts = (await getCollection('posts'))
  .filter(p => p.data.type === 'dev-return')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postCount = posts.length;
const seriesTotal = posts[0]?.data.seriesTotal ?? postCount;
const latestEntry = posts[0]?.data.seriesEntry;

// Progress pips: show up to 10, filled = completed entries
const MAX_PIPS = Math.min(seriesTotal, 10);
const filledPips = Math.min(latestEntry ?? 0, MAX_PIPS);
---

<BaseLayout
  title="Dev Return — BRAD.DEV"
  description="A series about coming back to the craft. The real work of returning to development."
  type="dev-return"
  activeLink="writing"
>
  <div class="site-wrapper">

    <section class="dr-hero scroll-reveal">
      <div class="dr-hero-text">
        <span class="dr-series-pill">
          Series &middot; {postCount} {postCount === 1 ? 'entry' : 'entries'}
        </span>
        <h1 class="dr-title">Dev<br />Return</h1>
        <p class="dr-tagline">Coming back to the craft.</p>

        {MAX_PIPS > 0 && (
          <div class="dr-pips" aria-label={`Series progress: ${filledPips} of ${MAX_PIPS}`}>
            {Array.from({ length: MAX_PIPS }, (_, i) => (
              <div class={`dr-pip${i < filledPips ? ' dr-pip--filled' : ''}${i === filledPips - 1 ? ' dr-pip--current' : ''}`}></div>
            ))}
          </div>
        )}
      </div>

      <div class="dr-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="160" height="160">
          <defs>
            <style>
              .dr-bg { transform-origin:50px 50px; animation:drPopIn 0.45s cubic-bezier(0.34,1.4,0.64,1) both; }
              @keyframes drPopIn { from{transform:scale(0.6);opacity:0} to{transform:scale(1);opacity:1} }
              .dr-pip-el { opacity:0; }
              .dr-p1{animation:drPipIn 0.2s 0.3s ease forwards}
              .dr-p2{animation:drPipIn 0.2s 0.5s ease forwards}
              .dr-p3{animation:drPipIn 0.2s 0.7s ease forwards}
              .dr-p4{animation:drPipIn 0.2s 0.9s ease forwards,drPipBlink 1.6s 1.1s ease-in-out infinite}
              @keyframes drPipIn{to{opacity:1}}
              @keyframes drPipBlink{0%,100%{opacity:1}50%{opacity:0.15}}
              .dr-chev1{stroke-dasharray:100;stroke-dashoffset:100;animation:drDrawChev 0.45s 0.5s cubic-bezier(0.4,0,0.2,1) forwards}
              .dr-chev2{stroke-dasharray:100;stroke-dashoffset:100;animation:drDrawChev 0.45s 0.65s cubic-bezier(0.4,0,0.2,1) forwards}
              @keyframes drDrawChev{to{stroke-dashoffset:0}}
              .dr-pdot{transform-origin:18px 82px;animation:drBounceIn 0.5s 0.75s cubic-bezier(0.34,1.8,0.64,1) both}
              @keyframes drBounceIn{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
              .dr-icon-group{cursor:pointer}
              .dr-icon-group:hover .dr-chev1{animation:drMarch 0.6s ease infinite}
              .dr-icon-group:hover .dr-chev2{animation:drMarch 0.6s 0.15s ease infinite}
              @keyframes drMarch{0%{transform:translateX(0);opacity:1}60%{transform:translateX(7px);opacity:0.4}61%{transform:translateX(-4px);opacity:0}100%{transform:translateX(0);opacity:1}}
              .dr-icon-group:hover .dr-p3{animation:drFlash 0.5s ease infinite}
              @keyframes drFlash{0%,100%{opacity:1}50%{opacity:0.2}}
            </style>
          </defs>
          <g class="dr-icon-group">
            <rect x="6" y="6" width="88" height="88" fill="#0d0d0d" opacity="0.15"/>
            <rect class="dr-bg" x="0" y="0" width="100" height="100" fill="#00E5FF" stroke="#0d0d0d" stroke-width="3"/>
            <rect class="dr-pip-el dr-p1" x="8"  y="8" width="16" height="10" fill="#0d0d0d"/>
            <rect class="dr-pip-el dr-p2" x="30" y="8" width="16" height="10" fill="#0d0d0d"/>
            <rect class="dr-pip-el dr-p3" x="52" y="8" width="16" height="10" fill="#0d0d0d"/>
            <rect class="dr-pip-el dr-p4" x="74" y="8" width="16" height="10" fill="#0d0d0d"/>
            <polyline class="dr-chev1" points="12,72 50,34 88,72" fill="none" stroke="#0d0d0d" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline class="dr-chev2" points="12,88 50,50 88,88" fill="none" stroke="#0d0d0d" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" opacity="0.25"/>
            <circle class="dr-pdot" cx="18" cy="82" r="7" fill="#C653FF" stroke="#0d0d0d" stroke-width="2.5"/>
          </g>
        </svg>
      </div>
    </section>

    <section class="posts-section scroll-reveal">
      <span class="section-label">// Dev Return</span>
      {posts.length > 0 ? (
        <div class="posts-grid">
          {posts.map(post => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="empty-state">No entries yet. Stay tuned.</p>
      )}
    </section>

  </div>
</BaseLayout>

<style>
.dr-hero {
  position: relative;
  background: var(--white);
  border-top: 4px solid var(--black);
  border-right: 4px solid var(--black);
  border-bottom: 4px solid var(--black);
  border-left: 8px solid var(--cyan);
  box-shadow: 10px 10px 0 var(--black);
  padding: 44px 40px 44px 36px;
  margin: 40px 0 52px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: center;
  overflow: hidden;
}

.dr-series-pill {
  display: inline-block;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--cyan);
  color: var(--black);
  border: 2px solid var(--black);
  padding: 4px 14px;
  margin-bottom: 16px;
}

.dr-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(3rem, 9vw, 5.5rem);
  letter-spacing: -0.04em;
  line-height: 0.88;
  color: var(--black);
  margin-bottom: 14px;
}

.dr-tagline {
  font-family: 'Space Mono', monospace;
  font-size: 0.78rem;
  color: rgba(13,13,13,0.55);
  margin-bottom: 24px;
  letter-spacing: 0.02em;
}

/* Progress pips */
.dr-pips {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.dr-pip {
  width: 14px;
  height: 14px;
  background: rgba(13,13,13,0.12);
  border: 2px solid rgba(13,13,13,0.2);
}

.dr-pip--filled {
  background: var(--black);
  border-color: var(--black);
}

.dr-pip--current {
  background: var(--cyan);
  border-color: var(--black);
  box-shadow: 2px 2px 0 var(--black);
}

.dr-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(4deg) translateY(-8px);
  filter: drop-shadow(5px 5px 0 rgba(13,13,13,0.2));
  transition: transform 0.2s ease;
}
.dr-icon-wrap:hover {
  transform: rotate(1deg) translateY(-4px) scale(1.04);
}

.posts-section {
  margin-bottom: 80px;
}
.posts-section .section-label {
  margin-bottom: 28px;
  display: inline-block;
}
.posts-grid {
  margin-top: 20px;
}

.empty-state {
  font-family: 'Space Mono', monospace;
  font-size: 0.85rem;
  color: rgba(13,13,13,0.5);
  margin-top: 24px;
  padding: 32px;
  border: 2px dashed rgba(13,13,13,0.2);
  text-align: center;
}

.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.posts-section.scroll-reveal {
  transition-delay: 0.1s;
}

@media (max-width: 640px) {
  .dr-hero {
    grid-template-columns: 1fr;
    padding: 32px 24px 32px 20px;
    margin: 24px 0 40px;
  }
  .dr-icon-wrap { display: none; }
  .dr-title { font-size: clamp(2.8rem, 14vw, 4rem); }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
