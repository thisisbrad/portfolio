---
interface Props {
  title: string;
  date: Date;
  readTime: string;
  tags: string[];
  subtitle?: string;
}
const { title, date, readTime, tags, subtitle } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<div class="post-header search-header">
  <div class="section-badge badge-with-icon">
    <span class="badge-icon-burst" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 140" width="240" height="280">
        <defs>
          <style>
            .sr-label {
              font-family: 'Bricolage Grotesque', 'Arial Black', sans-serif;
              font-size: 11px;
              font-weight: 800;
              letter-spacing: 2px;
              text-transform: uppercase;
              fill: #f5f0e8;
            }
            .sr-bg-sq {
              transform-origin: 60px 60px;
              animation: srSquareIn 0.45s cubic-bezier(0.34,1.4,0.64,1) both;
            }
            @keyframes srSquareIn {
              from { transform: scale(0.5); opacity: 0; }
              to   { transform: scale(1);   opacity: 1; }
            }
            .sr-coral-ring-1 {
              transform-origin: 60px 60px;
              animation: srRingExpand 0.5s 0.15s cubic-bezier(0.34,1.4,0.64,1) both;
            }
            .sr-coral-ring-2 {
              transform-origin: 60px 60px;
              animation: srRingExpand 0.5s 0.25s cubic-bezier(0.34,1.4,0.64,1) both;
            }
            .sr-coral-ring-3 {
              transform-origin: 60px 60px;
              animation: srRingExpand 0.5s 0.35s cubic-bezier(0.34,1.4,0.64,1) both;
            }
            .sr-center-dot {
              transform-origin: 60px 60px;
              animation: srRingExpand 0.4s 0.45s cubic-bezier(0.34,1.8,0.64,1) both;
            }
            @keyframes srRingExpand {
              from { transform: scale(0); opacity: 0; }
              to   { transform: scale(1); opacity: 1; }
            }
            .sr-ch {
              stroke-dasharray: 12;
              stroke-dashoffset: 12;
              animation: srDrawCH 0.3s ease forwards;
            }
            .sr-ch1 { animation-delay: 0.55s; }
            .sr-ch2 { animation-delay: 0.6s; }
            .sr-ch3 { animation-delay: 0.65s; }
            .sr-ch4 { animation-delay: 0.7s; }
            @keyframes srDrawCH {
              to { stroke-dashoffset: 0; }
            }
            .sr-scanning-ring {
              transform-origin: 60px 60px;
              animation:
                srRingExpand 0.5s 0.15s cubic-bezier(0.34,1.4,0.64,1) both,
                srSpin 8s 0.65s linear infinite;
            }
            .sr-orbit {
              transform-origin: 60px 60px;
              stroke-dasharray: 6 10;
              opacity: 0;
              animation: srOrbitIn 0.4s 0.8s ease forwards, srSpin 5s 1.2s linear infinite;
            }
            @keyframes srOrbitIn {
              to { opacity: 0.35; }
            }
            @keyframes srSpin {
              from { transform: rotate(0deg); }
              to   { transform: rotate(360deg); }
            }
            .sr-icon-group { cursor: pointer; }
            .sr-icon-group:hover .sr-orbit {
              animation: srSpin 1.5s linear infinite;
              opacity: 0.6;
            }
            .sr-icon-group:hover .sr-center-dot {
              animation: srDotPulse 0.6s ease infinite;
            }
            @keyframes srDotPulse {
              0%, 100% { r: 5; }
              50%       { r: 8; }
            }
            .sr-label-wrap {
              animation: srFadeUp 0.4s 0.7s ease both;
            }
            @keyframes srFadeUp {
              from { opacity: 0; transform: translateY(6px); }
              to   { opacity: 1; transform: translateY(0); }
            }
          </style>
          <clipPath id="sr-clip-2">
            <rect x="20" y="20" width="80" height="80"/>
          </clipPath>
        </defs>
        <g class="sr-icon-group">
          <rect x="26" y="26" width="80" height="80" fill="#FF4D6A" opacity="0.25"/>
          <rect class="sr-bg-sq" x="20" y="20" width="80" height="80" fill="#0d0d0d" stroke="#FF4D6A" stroke-width="3"/>
          <circle class="sr-scanning-ring" cx="60" cy="60" r="28" fill="#FF4D6A"/>
          <circle class="sr-coral-ring-2" cx="60" cy="60" r="18" fill="none" stroke="#0d0d0d" stroke-width="4"/>
          <circle class="sr-coral-ring-3" cx="60" cy="60" r="9"  fill="#0d0d0d"/>
          <circle class="sr-center-dot" cx="60" cy="60" r="5" fill="#FF4D6A"/>
          <circle class="sr-orbit" cx="60" cy="60" r="34" fill="none" stroke="#FF4D6A" stroke-width="1.5"/>
          <line class="sr-ch sr-ch1" x1="60" y1="24" x2="60" y2="32" stroke="#f5f0e8" stroke-width="2.5" stroke-linecap="round"/>
          <line class="sr-ch sr-ch2" x1="60" y1="88" x2="60" y2="96" stroke="#f5f0e8" stroke-width="2.5" stroke-linecap="round"/>
          <line class="sr-ch sr-ch3" x1="24" y1="60" x2="32" y2="60" stroke="#f5f0e8" stroke-width="2.5" stroke-linecap="round"/>
          <line class="sr-ch sr-ch4" x1="88" y1="60" x2="96" y2="60" stroke="#f5f0e8" stroke-width="2.5" stroke-linecap="round"/>
          <g class="sr-label-wrap">
            <text x="60" y="125" text-anchor="middle" class="sr-label">The Search</text>
          </g>
        </g>
      </svg>
    </span>
    The Search
  </div>
  <h1 class="post-title">{title}</h1>
  {subtitle && <p class="search-subtitle">{subtitle}</p>}
  <div class="post-meta">
    <span>{formattedDate}</span>
    <span class="meta-divider">&middot;</span>
    <span>{readTime}</span>
  </div>
  <div class="post-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>
