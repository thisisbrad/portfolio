---
interface Props {
  title: string;
  date: Date;
  readTime: string;
  tags: string[];
  subtitle?: string;
}
const { title, date, readTime, tags, subtitle } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<div class="post-header">
  <div class="section-badge">
    <span class="badge-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 18" width="18" height="18" aria-hidden="true" focusable="false">
        <rect x="1" y="1" width="16" height="16" fill="#0d0d0d" stroke="#ff4d6a" stroke-width="1.5"/>
        <circle cx="9" cy="9" r="5" fill="#ff4d6a"/>
        <circle cx="9" cy="9" r="2.5" fill="none" stroke="#0d0d0d" stroke-width="1.5"/>
        <circle cx="9" cy="9" r="0.8" fill="#ff4d6a"/>
        <line x1="9" y1="2" x2="9" y2="4.5" stroke="#f5f0e8" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="9" y1="13.5" x2="9" y2="16" stroke="#f5f0e8" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2" y1="9" x2="4.5" y2="9" stroke="#f5f0e8" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="13.5" y1="9" x2="16" y2="9" stroke="#f5f0e8" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span> The Search
  </div>
  <h1 class="post-title">{title}</h1>
  {subtitle && <p class="search-subtitle">{subtitle}</p>}
  <div class="post-meta">
    <span>{formattedDate}</span>
    <span class="meta-divider">&middot;</span>
    <span>{readTime}</span>
  </div>
  <div class="post-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>
