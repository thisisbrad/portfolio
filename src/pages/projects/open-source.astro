---
import BaseLayout from '../../layouts/BaseLayout.astro';

// ── Edit your open source contributions here ──────────────────────────────────
interface Contribution {
  project: string;
  description: string;
  type: 'fix' | 'feature' | 'docs' | 'review' | 'maintenance';
  tech: string[];
  status: 'live' | 'merged' | 'open' | 'archived';
  repo?: string;
  pr?: string;
  year: number;
}

const contributions: Contribution[] = [
  {
    project: 'Astro',
    description: 'Documentation improvements, component clarifications, and issue triage across the Astro framework ecosystem. Ongoing contributions as a site author and community member.',
    type: 'docs',
    tech: ['Astro', 'MDX', 'TypeScript'],
    status: 'live',
    repo: 'https://github.com/withastro/astro',
    pr: undefined,
    year: 2024,
  },
  {
    project: 'Open Source Contribution',
    description: 'Placeholder — add your open source contributions here. Include repo links, PR numbers, and a description of what you fixed or built.',
    type: 'feature',
    tech: ['TypeScript'],
    status: 'merged',
    repo: '#',
    pr: '#',
    year: 2024,
  },
];
// ─────────────────────────────────────────────────────────────────────────────

const typeLabels: Record<Contribution['type'], string> = {
  fix: '⚡ Bug Fix',
  feature: '◆ Feature',
  docs: '◈ Docs',
  review: '◎ Review',
  maintenance: '⊞ Maintenance',
};
---

<BaseLayout
  title="Open Source — BRAD.DEV"
  description="Code that lives in the open. Contributions to projects I use and believe in."
  type="projects"
  activeLink="projects"
>
  <div class="site-wrapper">

    <!-- Hero -->
    <section class="os-hero scroll-reveal">
      <div class="os-hero-text">
        <a href="/projects" class="os-back">← All Projects</a>
        <span class="os-eyebrow">// Code that lives in the open.</span>
        <h1 class="os-title">OPEN<br />SOURCE</h1>
        <div class="os-meta-row">
          <span class="os-count-pill">{contributions.length} contributions</span>
        </div>
      </div>

      <!-- Memphis deco: branching tree shapes -->
      <div class="os-deco" aria-hidden="true">
        <div class="os-branch os-branch--1"></div>
        <div class="os-branch os-branch--2"></div>
        <div class="os-branch os-branch--3"></div>
        <div class="os-node os-node--1"></div>
        <div class="os-node os-node--2"></div>
        <div class="os-node os-node--3"></div>
      </div>

      <div class="os-watermark" aria-hidden="true">{contributions.length}</div>
    </section>

    <!-- Contributions Grid -->
    <section class="contributions-section scroll-reveal">
      <span class="section-label">// Open Source</span>
      <div class="contributions-grid">
        {contributions.map(c => (
          <article class="contrib-card">

            <!-- Top: type badge + year -->
            <div class="contrib-top">
              <span class="contrib-type">{typeLabels[c.type]}</span>
              <span class="contrib-year">{c.year}</span>
            </div>

            <h2 class="contrib-project">{c.project}</h2>
            <p class="contrib-desc">{c.description}</p>

            <div class="contrib-tech">
              {c.tech.map(t => <span class="tech-pill">{t}</span>)}
            </div>

            <div class="contrib-footer">
              <span class={`contrib-status contrib-status--${c.status}`}>
                {c.status === 'live' ? '● Live'
                 : c.status === 'merged' ? '✓ Merged'
                 : c.status === 'open' ? '◐ Open'
                 : '○ Archived'}
              </span>
              <div class="contrib-links">
                {c.repo && c.repo !== '#' && (
                  <a href={c.repo} class="contrib-link" target="_blank" rel="noopener">Repo ↗</a>
                )}
                {c.pr && c.pr !== '#' && (
                  <a href={c.pr} class="contrib-link contrib-link--pr" target="_blank" rel="noopener">PR ↗</a>
                )}
              </div>
            </div>

          </article>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
/* ---- Hero ---- */
.os-hero {
  position: relative;
  background: #39ff14;
  border: 4px solid var(--black);
  box-shadow: 10px 10px 0 var(--black);
  padding: 44px 40px 40px;
  margin: 40px 0 52px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 24px;
}

/* Diagonal stripe texture */
.os-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    -45deg, transparent, transparent 18px,
    rgba(13,13,13,0.04) 18px, rgba(13,13,13,0.04) 20px
  );
  pointer-events: none;
}

.os-back {
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.04em;
  color: rgba(13,13,13,0.55);
  text-decoration: none;
  display: inline-block;
  margin-bottom: 14px;
  transition: color 0.12s;
}
.os-back:hover { color: var(--black); }

.os-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  color: rgba(13,13,13,0.6);
  display: block;
  margin-bottom: 10px;
}

.os-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(2.8rem, 8vw, 5rem);
  letter-spacing: -0.04em;
  line-height: 0.88;
  color: var(--black);
  margin-bottom: 24px;
}

.os-meta-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.os-count-pill {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: var(--black);
  color: #39ff14;
  padding: 5px 14px;
}

/* Branch / node Memphis deco */
.os-deco {
  position: relative;
  width: 120px;
  height: 140px;
  flex-shrink: 0;
  margin-top: 20px;
}

.os-branch {
  position: absolute;
  background: var(--black);
  border-radius: 2px;
}

.os-branch--1 {
  width: 4px;
  height: 70px;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.os-branch--2 {
  width: 4px;
  height: 40px;
  top: 40px;
  left: 20%;
  transform: rotate(30deg);
  transform-origin: top center;
}

.os-branch--3 {
  width: 4px;
  height: 40px;
  top: 40px;
  left: 65%;
  transform: rotate(-30deg);
  transform-origin: top center;
}

.os-node {
  position: absolute;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--black);
  border: 3px solid #39ff14;
}

.os-node--1 {
  top: -4px;
  left: 50%;
  transform: translateX(-50%);
  width: 22px;
  height: 22px;
}

.os-node--2 {
  top: 68px;
  left: 8%;
}

.os-node--3 {
  top: 68px;
  left: 68%;
}

.os-watermark {
  position: absolute;
  bottom: -14px;
  right: 160px;
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(6rem, 16vw, 11rem);
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 3px rgba(13,13,13,0.07);
  pointer-events: none;
  user-select: none;
}

.os-hero-text {
  position: relative;
  z-index: 1;
}

/* ---- Contributions grid ---- */
.contributions-section {
  margin-bottom: 80px;
}

.contributions-section .section-label {
  margin-bottom: 28px;
  display: inline-block;
}

.contributions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 0;
  border: 3px solid var(--black);
  box-shadow: 6px 6px 0 var(--black);
}

/* ---- Contribution card ---- */
.contrib-card {
  padding: 28px;
  border-right: 2px solid var(--black);
  border-bottom: 2px solid var(--black);
  display: flex;
  flex-direction: column;
  gap: 14px;
  background: var(--white);
  transition: background 0.15s;
  cursor: crosshair;
  position: relative;
}

/* Green top accent strip */
.contrib-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5px;
  background: #39ff14;
  border-bottom: 1.5px solid rgba(13,13,13,0.3);
}

.contrib-card:hover {
  background: color-mix(in srgb, #39ff14 5%, var(--white));
}

.contrib-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
}

.contrib-type {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(13,13,13,0.6);
  background: rgba(57, 255, 20, 0.15);
  border: 1.5px solid rgba(13,13,13,0.2);
  padding: 3px 8px;
}

.contrib-year {
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  color: rgba(13,13,13,0.4);
}

.contrib-project {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: 1.35rem;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--black);
}

.contrib-desc {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 0.85rem;
  line-height: 1.6;
  color: rgba(13,13,13,0.7);
  flex: 1;
}

.contrib-tech {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tech-pill {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.04em;
  padding: 3px 8px;
  border: 1.5px solid rgba(13,13,13,0.3);
  color: rgba(13,13,13,0.65);
}

.contrib-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding-top: 12px;
  border-top: 2px solid rgba(13,13,13,0.1);
  margin-top: auto;
}

.contrib-status {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 3px 8px;
  border: 1.5px solid currentColor;
}

.contrib-status--live,
.contrib-status--merged {
  color: #1a7a00;
  background: rgba(57, 255, 20, 0.1);
}

.contrib-status--open {
  color: var(--orange);
  background: rgba(255, 122, 0, 0.08);
}

.contrib-status--archived {
  color: rgba(13,13,13,0.4);
}

.contrib-links {
  display: flex;
  gap: 8px;
}

.contrib-link {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 5px 12px;
  border: 2px solid var(--black);
  color: var(--black);
  background: transparent;
  box-shadow: 3px 3px 0 var(--black);
  transition: transform 0.1s, box-shadow 0.1s;
  cursor: crosshair;
}

.contrib-link:hover {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 var(--black);
}

.contrib-link--pr {
  background: #39ff14;
}

/* ---- Scroll reveal ---- */
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.contributions-section.scroll-reveal { transition-delay: 0.1s; }

/* ---- Responsive ---- */
@media (max-width: 640px) {
  .os-hero {
    grid-template-columns: 1fr;
    padding: 32px 24px;
    margin: 24px 0 40px;
  }
  .os-deco { display: none; }
  .os-watermark { right: 16px; }
  .contributions-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
