---
interface Props {
  title: string;
  date: Date;
  readTime: string;
  tags: string[];
  logNumber?: number;
  techStack?: string;
}
const { title, date, readTime, tags, logNumber, techStack } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<div class="post-header buildlog-header">
  <div class="post-header-deco">
    {logNumber && <span class="buildlog-number">{String(logNumber).padStart(2, '0')}</span>}
    <div>
      <div class="section-badge badge-with-icon">
        <span class="badge-icon-burst" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 140" width="240" height="280">
            <defs>
              <style>
                .bl-label {
                  font-family: 'Bricolage Grotesque', 'Arial Black', sans-serif;
                  font-size: 11px;
                  font-weight: 800;
                  letter-spacing: 2px;
                  text-transform: uppercase;
                  fill: #0d0d0d;
                }
                .bl-dot-ping {
                  transform-origin: 108px 12px;
                  animation: blPing 2.2s ease-out infinite;
                }
                @keyframes blPing {
                  0%   { opacity: 1;   transform: scale(1); }
                  70%  { opacity: 0;   transform: scale(2.6); }
                  100% { opacity: 0;   transform: scale(2.6); }
                }
                .bl-zz {
                  stroke-dasharray: 60;
                  stroke-dashoffset: 60;
                  animation: blDraw 0.7s 0.3s cubic-bezier(0.4,0,0.2,1) forwards;
                }
                @keyframes blDraw {
                  to { stroke-dashoffset: 0; }
                }
                .bl-inset-sq {
                  transform-origin: 80px 80px;
                  animation: blSlideIn 0.55s 0.15s cubic-bezier(0.34,1.56,0.64,1) both;
                }
                @keyframes blSlideIn {
                  from { transform: translate(12px, 12px); opacity: 0; }
                  to   { transform: translate(0, 0);       opacity: 1; }
                }
                .bl-outer-sq {
                  transform-origin: 20px 20px;
                  animation: blPopIn 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
                }
                @keyframes blPopIn {
                  from { transform: scale(0.6) rotate(-6deg); opacity: 0; }
                  to   { transform: scale(1)   rotate(0deg);  opacity: 1; }
                }
                .bl-icon-group { cursor: pointer; }
                .bl-icon-group:hover .bl-outer-sq {
                  animation: blWobble 0.5s ease;
                }
                @keyframes blWobble {
                  0%   { transform: rotate(0deg); }
                  25%  { transform: rotate(-4deg); }
                  50%  { transform: rotate(4deg); }
                  75%  { transform: rotate(-2deg); }
                  100% { transform: rotate(0deg); }
                }
                .bl-icon-group:hover .bl-dot-ping {
                  animation: blPing 0.8s ease-out infinite;
                }
                .bl-stripe { opacity: 0; animation: blFadeIn 0.3s ease forwards; }
                .bl-s1 { animation-delay: 0.5s; }
                .bl-s2 { animation-delay: 0.6s; }
                .bl-s3 { animation-delay: 0.7s; }
                .bl-s4 { animation-delay: 0.8s; }
                .bl-s5 { animation-delay: 0.9s; }
                .bl-s6 { animation-delay: 1.0s; }
                @keyframes blFadeIn { to { opacity: 0.18; } }
                .bl-label-wrap {
                  animation: blFadeUp 0.4s 0.6s ease both;
                }
                @keyframes blFadeUp {
                  from { opacity: 0; transform: translateY(6px); }
                  to   { opacity: 1; transform: translateY(0); }
                }
              </style>
              <clipPath id="bl-clip-2">
                <rect x="20" y="20" width="80" height="80"/>
              </clipPath>
            </defs>
            <g class="bl-icon-group">
              <rect x="26" y="26" width="80" height="80" fill="#0d0d0d" opacity="0.18"/>
              <rect class="bl-outer-sq" x="20" y="20" width="80" height="80" fill="#FFE600" stroke="#0d0d0d" stroke-width="3"/>
              <g clip-path="url(#bl-clip-2)">
                <line class="bl-stripe bl-s1" x1="10"  y1="40"  x2="60"  y2="-10" stroke="#0d0d0d" stroke-width="2"/>
                <line class="bl-stripe bl-s2" x1="10"  y1="65"  x2="85"  y2="-10" stroke="#0d0d0d" stroke-width="2"/>
                <line class="bl-stripe bl-s3" x1="10"  y1="90"  x2="100" y2="-10" stroke="#0d0d0d" stroke-width="2"/>
                <line class="bl-stripe bl-s4" x1="15"  y1="105" x2="105" y2="15"  stroke="#0d0d0d" stroke-width="2"/>
                <line class="bl-stripe bl-s5" x1="40"  y1="110" x2="105" y2="45"  stroke="#0d0d0d" stroke-width="2"/>
                <line class="bl-stripe bl-s6" x1="65"  y1="110" x2="105" y2="70"  stroke="#0d0d0d" stroke-width="2"/>
              </g>
              <rect class="bl-inset-sq" x="64" y="64" width="32" height="32" fill="#0d0d0d"/>
              <polyline class="bl-zz" points="20,65 32,53 44,65 56,53 68,65 80,53 92,65 100,55"
                fill="none" stroke="#0d0d0d" stroke-width="3"
                stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="108" cy="12" r="8" fill="#39FF14" stroke="#0d0d0d" stroke-width="2.5"/>
              <circle class="bl-dot-ping" cx="108" cy="12" r="8" fill="none" stroke="#39FF14" stroke-width="2"/>
              <g class="bl-label-wrap">
                <text x="60" y="125" text-anchor="middle" class="bl-label">Build Log</text>
              </g>
            </g>
          </svg>
        </span>
        Build Log
      </div>
    </div>
  </div>
  <h1 class="post-title">
    <span class="underline-accent">{title}</span>
  </h1>
  <div class="post-meta">
    <span>{formattedDate}</span>
    <span class="meta-divider">&middot;</span>
    <span>{readTime}</span>
    {techStack && (
      <>
        <span class="meta-divider">&middot;</span>
        <span>{techStack}</span>
      </>
    )}
  </div>
  <div class="post-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>
