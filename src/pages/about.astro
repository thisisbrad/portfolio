---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — BRAD.DEV"
  description="A decade of teaching, building, and leading. Full-stack developer, former educator, perpetual tinkerer."
  activeLink="about"
>
  <div class="site-wrapper">

    <!-- Hero -->
    <section class="about-hero scroll-reveal">
      <div class="about-hero-text">
        <span class="about-label">// About</span>
        <h1 class="about-title">Ten years<br /><span class="about-title-accent">in the work.</span></h1>
        <p class="about-intro">
          I started in front of a classroom. Now I build what I used to teach.
          A decade of explaining hard things clearly — to students, to teammates,
          to anyone who'd listen — turns out to be the best training for writing
          clean, readable code and leading teams that actually ship.
        </p>
      </div>
      <div class="about-hero-badge-col">
        <div class="about-stat-block">
          <span class="about-stat-num">10<span class="about-stat-plus">+</span></span>
          <span class="about-stat-label">Years in the craft</span>
        </div>
        <div class="about-stat-block">
          <span class="about-stat-num">2</span>
          <span class="about-stat-label">Careers in one</span>
        </div>
        <div class="about-stat-block">
          <span class="about-stat-num">∞</span>
          <span class="about-stat-label">Things still to build</span>
        </div>
      </div>
      <div class="about-deco-bar" aria-hidden="true"></div>
    </section>

    <!-- Timeline -->
    <section class="about-section scroll-reveal">
      <span class="section-label about-section-label">// The Decade</span>
      <div class="timeline">

        <div class="tl-item">
          <div class="tl-marker"></div>
          <div class="tl-content">
            <span class="tl-year">Early Career</span>
            <h3 class="tl-heading">The classroom first.</h3>
            <p class="tl-body">
              Before the terminal, there was a whiteboard. Teaching gave me a framework
              for breaking down complexity — skills that transfer directly to code review,
              documentation, and mentorship. You can't fake understanding when a room
              full of people is waiting for you to explain it.
            </p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-marker tl-marker--cyan"></div>
          <div class="tl-content">
            <span class="tl-year">The Pivot</span>
            <h3 class="tl-heading">Into the stack.</h3>
            <p class="tl-body">
              JavaScript grabbed me first. Then Node. Then the whole full-stack picture
              snapped into focus — front to back, browser to database. I stopped teaching
              other subjects and started teaching myself how to build real things.
            </p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-marker tl-marker--yellow"></div>
          <div class="tl-content">
            <span class="tl-year">Building</span>
            <h3 class="tl-heading">Production code, real teams.</h3>
            <p class="tl-body">
              React, Next.js, Express, PostgreSQL, MongoDB — not on side projects,
              in production. Learned what "done" actually means when users depend on it.
              Shipped features, fixed regressions, survived deploys. Moved into
              leadership without leaving the code behind.
            </p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-marker tl-marker--coral"></div>
          <div class="tl-content">
            <span class="tl-year">Leadership</span>
            <h3 class="tl-heading">Teams, not just tickets.</h3>
            <p class="tl-body">
              Led engineers without losing the IC muscle. Code review, architecture
              decisions, sprint planning, hiring — but still writing code. The classroom
              background paid dividends here: leading a team is just teaching at a
              different cadence.
            </p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-marker tl-marker--orange"></div>
          <div class="tl-content">
            <span class="tl-year">Now</span>
            <h3 class="tl-heading">Building in public.</h3>
            <p class="tl-body">
              Back to fundamentals — building this site from scratch, documenting the
              job search, shipping side projects. Writing about all of it. If I'm going
              to be between roles, I'm going to use the time well.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- Teaching → Dev -->
    <section class="about-section scroll-reveal">
      <span class="section-label about-section-label">// Why Teaching Matters</span>
      <div class="teaching-grid">
        <div class="teaching-copy">
          <h2 class="teaching-heading">The classroom<br />never left me.</h2>
          <p class="teaching-body">
            Teaching isn't something I did before development — it's something
            I bring into development every day. Writing documentation anyone
            actually reads. Giving code reviews that explain the why, not just
            the what. Onboarding new engineers without losing a week of velocity.
          </p>
          <p class="teaching-body">
            The best engineers I've worked with could explain a complex system
            to a junior in ten minutes. That's not a soft skill — it's a
            force multiplier. A decade of classrooms made it automatic for me.
          </p>
        </div>
        <div class="teaching-callouts">
          <div class="teaching-callout tc-yellow">
            <span class="tc-icon">⎆</span>
            <span class="tc-label">Communication</span>
            <p class="tc-text">Writing and speaking precisely. No ambiguity in specs, PRs, or retros.</p>
          </div>
          <div class="teaching-callout tc-cyan">
            <span class="tc-icon">◎</span>
            <span class="tc-label">Mentorship</span>
            <p class="tc-text">Growing junior engineers into confident contributors. Not doing it for them.</p>
          </div>
          <div class="teaching-callout tc-coral">
            <span class="tc-icon">◈</span>
            <span class="tc-label">Clarity</span>
            <p class="tc-text">Breaking systems into their smallest honest parts. Then explaining those parts.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="about-section scroll-reveal">
      <span class="section-label about-section-label">// What I Build With</span>
      <div class="stack-grid">
        <div class="stack-col">
          <h3 class="stack-col-heading">Frontend</h3>
          <ul class="stack-list">
            <li>JavaScript / TypeScript</li>
            <li>React</li>
            <li>Next.js</li>
            <li>Astro</li>
          </ul>
        </div>
        <div class="stack-col">
          <h3 class="stack-col-heading">Backend</h3>
          <ul class="stack-list">
            <li>Node.js</li>
            <li>Express</li>
            <li>REST APIs</li>
          </ul>
        </div>
        <div class="stack-col">
          <h3 class="stack-col-heading">Data</h3>
          <ul class="stack-list">
            <li>PostgreSQL</li>
            <li>MongoDB</li>
            <li>Drizzle ORM</li>
          </ul>
        </div>
        <div class="stack-col">
          <h3 class="stack-col-heading">Platform</h3>
          <ul class="stack-list">
            <li>Cloudflare</li>
            <li>Vercel</li>
            <li>Git / GitHub</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Connect -->
    <section class="about-section about-connect scroll-reveal">
      <span class="section-label about-section-label">// Let's Talk</span>
      <div class="connect-inner">
        <h2 class="connect-heading">Open to the right role.</h2>
        <p class="connect-body">
          Full-stack JS, React, Node. Leadership or IC. I write about the
          search as it happens — no spin, just the reality of it. If something
          here resonates, reach out.
        </p>
        <div class="connect-links">
          <a href="https://github.com/" target="_blank" rel="noopener noreferrer" class="connect-btn connect-btn--black">
            GitHub →
          </a>
          <a href="https://linkedin.com/" target="_blank" rel="noopener noreferrer" class="connect-btn connect-btn--cyan">
            LinkedIn →
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
/* ---- Hero -------------------------------------------------- */
.about-hero {
  position: relative;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: start;
  border: 4px solid var(--black);
  box-shadow: 10px 10px 0 var(--cyan);
  background: var(--white);
  padding: 52px 44px;
  margin: 40px 0 52px;
  overflow: hidden;
}

.about-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.04em;
  color: rgba(13,13,13,0.5);
  display: block;
  margin-bottom: 16px;
}

.about-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(2.8rem, 8vw, 5rem);
  letter-spacing: -0.04em;
  line-height: 0.9;
  color: var(--black);
  margin-bottom: 24px;
}

.about-title-accent {
  background: var(--cyan);
  padding: 0 6px;
  display: inline;
}

.about-intro {
  font-family: 'Lora', serif;
  font-size: 1.05rem;
  line-height: 1.75;
  color: rgba(13,13,13,0.75);
  max-width: 56ch;
}

.about-hero-badge-col {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 3px solid var(--black);
  flex-shrink: 0;
}

.about-stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px 28px;
  border-bottom: 3px solid var(--black);
  text-align: center;
}

.about-stat-block:last-child {
  border-bottom: none;
}

.about-stat-num {
  font-family: 'Archivo Black', sans-serif;
  font-size: 2.8rem;
  line-height: 1;
  color: var(--black);
  display: block;
}

.about-stat-plus {
  font-size: 1.8rem;
  vertical-align: super;
}

.about-stat-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: rgba(13,13,13,0.5);
  margin-top: 4px;
  display: block;
}

/* Decorative bottom bar */
.about-deco-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6px;
  background: repeating-linear-gradient(
    90deg,
    var(--cyan) 0px,
    var(--cyan) 24px,
    var(--black) 24px,
    var(--black) 28px
  );
}

/* ---- Section shared ---------------------------------------- */
.about-section {
  margin-bottom: 72px;
}

.about-section-label {
  background: var(--cyan) !important;
  color: var(--black) !important;
  display: inline-block;
  margin-bottom: 32px;
}

/* ---- Timeline ---------------------------------------------- */
.timeline {
  display: block;
  border-left: 4px solid var(--black);
  margin-left: 12px;
  width: 100%;
}

.tl-item {
  position: relative;
  padding-bottom: 40px;
  width: 100%;
}

.tl-item:last-child {
  padding-bottom: 0;
}

.tl-marker {
  position: absolute;
  left: -10px;
  top: 4px;
  width: 16px;
  height: 16px;
  background: var(--black);
  border: 3px solid var(--white);
  outline: 3px solid var(--black);
  flex-shrink: 0;
}

.tl-marker--cyan   { background: var(--cyan); }
.tl-marker--yellow { background: var(--yellow); }
.tl-marker--coral  { background: var(--coral); }
.tl-marker--orange { background: var(--orange); }

.tl-content {
  padding-left: 32px;
}

.tl-year {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: rgba(13,13,13,0.45);
  display: block;
  margin-bottom: 6px;
}

.tl-heading {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(1.2rem, 3vw, 1.6rem);
  letter-spacing: -0.025em;
  color: var(--black);
  margin-bottom: 10px;
}

.tl-body {
  font-family: 'Lora', serif;
  font-size: 0.95rem;
  line-height: 1.75;
  color: rgba(13,13,13,0.7);
}

/* ---- Teaching grid ----------------------------------------- */
.teaching-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

.teaching-heading {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  letter-spacing: -0.03em;
  line-height: 0.95;
  color: var(--black);
  margin-bottom: 20px;
}

.teaching-body {
  font-family: 'Lora', serif;
  font-size: 0.95rem;
  line-height: 1.8;
  color: rgba(13,13,13,0.7);
  margin-bottom: 14px;
  max-width: 52ch;
}

.teaching-callouts {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 3px solid var(--black);
}

.teaching-callout {
  padding: 20px 22px;
  border-bottom: 3px solid var(--black);
  display: grid;
  grid-template-columns: auto 1fr;
  grid-template-rows: auto auto;
  column-gap: 14px;
  row-gap: 4px;
}

.teaching-callout:last-child {
  border-bottom: none;
}

.tc-yellow { border-left: 6px solid var(--yellow); }
.tc-cyan   { border-left: 6px solid var(--cyan); }
.tc-coral  { border-left: 6px solid var(--coral); }

.tc-icon {
  font-size: 1.3rem;
  line-height: 1;
  grid-row: 1 / 3;
  align-self: center;
}

.tc-label {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.78rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--black);
  align-self: end;
}

.tc-text {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  line-height: 1.5;
  color: rgba(13,13,13,0.55);
  align-self: start;
}

/* ---- Stack grid -------------------------------------------- */
.stack-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 3px solid var(--black);
}

.stack-col {
  padding: 24px 22px;
  border-right: 3px solid var(--black);
}

.stack-col:last-child {
  border-right: none;
}

.stack-col-heading {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  background: var(--black);
  color: var(--cyan);
  padding: 4px 10px;
  display: inline-block;
  margin-bottom: 16px;
}

.stack-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.stack-list li {
  font-family: 'Space Mono', monospace;
  font-size: 0.72rem;
  color: var(--black);
  padding-left: 14px;
  position: relative;
}

.stack-list li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--cyan);
  font-weight: 700;
}

/* ---- Connect ----------------------------------------------- */
.about-connect {
  border: 4px solid var(--black);
  box-shadow: 10px 10px 0 var(--black);
  background: var(--black);
  padding: 48px 44px;
  margin-bottom: 80px;
}

.about-connect .about-section-label {
  background: var(--cyan) !important;
  color: var(--black) !important;
}

.connect-heading {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 800;
  font-size: clamp(1.8rem, 5vw, 3rem);
  letter-spacing: -0.035em;
  color: var(--white);
  margin-bottom: 16px;
}

.connect-body {
  font-family: 'Lora', serif;
  font-size: 1rem;
  line-height: 1.75;
  color: rgba(245,240,232,0.65);
  max-width: 52ch;
  margin-bottom: 32px;
}

.connect-links {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.connect-btn {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.8rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 12px 28px;
  border: 3px solid var(--white);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
  display: inline-block;
}

.connect-btn--black {
  background: var(--white);
  color: var(--black);
  box-shadow: 5px 5px 0 rgba(245,240,232,0.25);
}

.connect-btn--black:hover {
  transform: translate(-2px, -2px);
  box-shadow: 7px 7px 0 rgba(245,240,232,0.25);
}

.connect-btn--cyan {
  background: var(--cyan);
  color: var(--black);
  border-color: var(--cyan);
  box-shadow: 5px 5px 0 var(--cyan);
}

.connect-btn--cyan:hover {
  transform: translate(-2px, -2px);
  box-shadow: 7px 7px 0 var(--cyan);
}

/* ---- Scroll reveal ----------------------------------------- */
.scroll-reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s cubic-bezier(0.4,0,0.2,1), transform 0.55s cubic-bezier(0.4,0,0.2,1);
}
.scroll-reveal.is-visible {
  opacity: 1;
  transform: none;
}
.about-section.scroll-reveal { transition-delay: 0.08s; }

/* ---- Responsive -------------------------------------------- */
@media (max-width: 900px) {
  .teaching-grid {
    grid-template-columns: 1fr;
  }
  .stack-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .stack-col:nth-child(2) {
    border-right: none;
  }
  .stack-col:nth-child(3) {
    border-top: 3px solid var(--black);
  }
  .stack-col:nth-child(4) {
    border-top: 3px solid var(--black);
    border-right: none;
  }
}

@media (max-width: 640px) {
  .about-hero {
    grid-template-columns: 1fr;
    padding: 36px 24px;
    margin: 24px 0 40px;
  }
  .about-hero-badge-col {
    flex-direction: row;
    border: 3px solid var(--black);
  }
  .about-stat-block {
    flex: 1;
    padding: 14px 12px;
    border-bottom: none;
    border-right: 3px solid var(--black);
  }
  .about-stat-block:last-child {
    border-right: none;
  }
  .about-stat-num {
    font-size: 2rem;
  }
  .stack-grid {
    grid-template-columns: 1fr;
  }
  .stack-col {
    border-right: none;
    border-bottom: 3px solid var(--black);
  }
  .stack-col:last-child {
    border-bottom: none;
  }
  .stack-col:nth-child(n) {
    border-top: none;
  }
  .about-connect {
    padding: 32px 24px;
  }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const revealEls = document.querySelectorAll('.scroll-reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      revealEls.forEach(el => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>
