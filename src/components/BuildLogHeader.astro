---
interface Props {
  title: string;
  date: Date;
  readTime: string;
  tags: string[];
  logNumber?: number;
  techStack?: string;
}
const { title, date, readTime, tags, logNumber, techStack } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<div class="post-header buildlog-header">
  <div class="post-header-deco">
    {logNumber && <span class="buildlog-number">{String(logNumber).padStart(2, '0')}</span>}
    <div>
      <div class="section-badge badge-with-icon">
        <span class="badge-icon-burst" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="240" height="240" overflow="hidden">
  <defs>
    <style>
      .outer-sq {
        transform-origin: 50px 50px;
        animation: popIn 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
      }
      @keyframes popIn {
        from { transform: scale(0.6) rotate(-6deg); opacity: 0; }
        to   { transform: scale(1) rotate(0deg); opacity: 1; }
      }
      .inset-sq {
        transform-origin: 50px 50px;
        animation: slideIn 0.55s 0.15s cubic-bezier(0.34,1.56,0.64,1) both;
      }
      @keyframes slideIn {
        from { transform: translate(10px, 10px); opacity: 0; }
        to   { transform: translate(0, 0); opacity: 1; }
      }
      .stripe { opacity: 0; animation: fadeIn 0.3s ease forwards; }
      .s1 { animation-delay: 0.5s; }
      .s2 { animation-delay: 0.6s; }
      .s3 { animation-delay: 0.7s; }
      .s4 { animation-delay: 0.8s; }
      .s5 { animation-delay: 0.9s; }
      .s6 { animation-delay: 1.0s; }
      @keyframes fadeIn { to { opacity: 0.18; } }
      .zz {
        stroke-dasharray: 60;
        stroke-dashoffset: 60;
        animation: draw 0.7s 0.3s cubic-bezier(0.4,0,0.2,1) forwards;
      }
      @keyframes draw { to { stroke-dashoffset: 0; } }
      .dot-ping {
        transform-origin: 78px 22px;
        animation: ping 2.2s ease-out infinite;
      }
      @keyframes ping {
        0%   { opacity: 1; transform: scale(1); }
        70%  { opacity: 0; transform: scale(2.4); }
        100% { opacity: 0; transform: scale(2.4); }
      }
      .icon-group { cursor: pointer; }
      .icon-group:hover .outer-sq { animation: wobble 0.5s ease; }
      @keyframes wobble {
        0%   { transform: rotate(0deg); }
        25%  { transform: rotate(-4deg); }
        50%  { transform: rotate(4deg); }
        75%  { transform: rotate(-2deg); }
        100% { transform: rotate(0deg); }
      }
    </style>
    <clipPath id="bl-clip">
      <rect x="8" y="8" width="84" height="84"/>
    </clipPath>
  </defs>

  <g class="icon-group">
    <rect x="14" y="14" width="84" height="84" fill="#0d0d0d" opacity="0.15"/>
    <rect class="outer-sq" x="8" y="8" width="84" height="84" fill="#FFE600" stroke="#0d0d0d" stroke-width="3"/>
    <g clip-path="url(#bl-clip)">
      <line class="stripe s1" x1="-5"  y1="35"  x2="55"  y2="-5"  stroke="#0d0d0d" stroke-width="2"/>
      <line class="stripe s2" x1="-5"  y1="58"  x2="78"  y2="-5"  stroke="#0d0d0d" stroke-width="2"/>
      <line class="stripe s3" x1="-5"  y1="82"  x2="95"  y2="-5"  stroke="#0d0d0d" stroke-width="2"/>
      <line class="stripe s4" x1="8"   y1="96"  x2="96"  y2="8"   stroke="#0d0d0d" stroke-width="2"/>
      <line class="stripe s5" x1="32"  y1="96"  x2="96"  y2="32"  stroke="#0d0d0d" stroke-width="2"/>
      <line class="stripe s6" x1="58"  y1="96"  x2="96"  y2="58"  stroke="#0d0d0d" stroke-width="2"/>
    </g>
    <rect class="inset-sq" x="56" y="56" width="34" height="34" fill="#0d0d0d"/>
    <polyline class="zz" points="8,62 20,48 32,62 44,48 56,62 68,48 80,62 92,50"
      fill="none" stroke="#0d0d0d" stroke-width="3.5"
      stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="78" cy="22" r="9" fill="#39FF14" stroke="#0d0d0d" stroke-width="2.5"/>
    <circle class="dot-ping" cx="78" cy="22" r="9" fill="none" stroke="#39FF14" stroke-width="2"/>
  </g>
</svg>
        </span>
        Build Log
      </div>
    </div>
  </div>
  <h1 class="post-title">
    <span class="underline-accent">{title}</span>
  </h1>
  <div class="post-meta">
    <span>{formattedDate}</span>
    <span class="meta-divider">&middot;</span>
    <span>{readTime}</span>
    {techStack && (
      <>
        <span class="meta-divider">&middot;</span>
        <span>{techStack}</span>
      </>
    )}
  </div>
  <div class="post-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>
